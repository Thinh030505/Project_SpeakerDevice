doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{typeof pageTitle !== 'undefined' ? pageTitle + ' - SoundHouse' : 'SoundHouse'}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet")
    style.
      :root {
        --primary: #3D3E5B;
        --primary-dark: #2f3048;
        --primary-deep: #26273d;
        --bg: #f6f7fb;
        --bg-soft: #eef0f7;
        --surface: #ffffff;
        --surface-tint: rgba(61, 62, 91, 0.06);
        --line: rgba(61, 62, 91, 0.14);
        --line-soft: rgba(255, 255, 255, 0.14);
        --text: #171826;
        --text-soft: #4b4d63;
        --muted: #76798e;
        --text-invert: #ffffff;
        --muted-invert: rgba(255, 255, 255, 0.74);
        --accent: #f2c46d;
        --accent-2: #ff9f5a;
        --danger: #fb7185;
        --success: #34d399;
        --warning: #fbbf24;
        --shadow: 0 20px 48px rgba(41, 42, 63, 0.16);
        --radius: 18px;
        --shell: min(1280px, calc(100% - 48px));
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Manrope", system-ui, sans-serif;
        color: var(--text);
        background:
          linear-gradient(180deg, rgba(61, 62, 91, 0.08), rgba(246, 247, 251, 0) 320px),
          var(--bg);
      }
      a { color: inherit; }
      img { max-width: 100%; display: block; }
      button, input, select, textarea { font: inherit; }
      button:disabled,
      .btn[aria-disabled="true"],
      .btn-ghost[aria-disabled="true"] {
        cursor: not-allowed;
        opacity: 0.62;
      }
      .shell {
        width: var(--shell);
        margin: 0 auto;
      }
      .topbar {
        background: var(--primary-dark);
        color: rgba(255, 255, 255, 0.78);
      }
      .topbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        min-height: 36px;
        font-size: 13px;
      }
      .topbar__contact,
      .topbar__links {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
      }
      .topbar a {
        text-decoration: none;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 40;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(61, 62, 91, 0.72);
        color: var(--text-invert);
        backdrop-filter: blur(16px);
        transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .site-header.is-scrolled {
        background: rgba(61, 62, 91, 0.96);
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 12px 32px rgba(37, 38, 60, 0.2);
      }
      .site-header__bar {
        display: grid;
        grid-template-columns: auto minmax(360px, 1fr) minmax(220px, 340px) auto;
        align-items: center;
        gap: 24px;
        min-height: 78px;
      }
      .site-header__brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 178px;
        text-decoration: none;
      }
      .site-header__menu {
        display: none;
      }
      .site-header__logo {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #24253a;
        font-family: "Space Grotesk", sans-serif;
        font-weight: 700;
        box-shadow: 0 12px 24px rgba(242, 196, 109, 0.22);
      }
      .site-header__brand strong {
        display: block;
        font-family: "Space Grotesk", sans-serif;
        font-size: 25px;
        line-height: 1;
      }
      .site-header__brand span {
        display: block;
        margin-top: 4px;
        color: rgba(255, 255, 255, 0.62);
        font-size: 12px;
      }
      .site-header__nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 24px;
      }
      .site-header__nav a {
        position: relative;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: color 0.3s ease;
      }
      .site-header__nav a::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -9px;
        height: 2px;
        border-radius: 999px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.3s ease;
      }
      .site-header__nav a:hover,
      .site-header__nav a:focus-visible {
        color: #fff;
      }
      .site-header__nav a:hover::after,
      .site-header__nav a:focus-visible::after {
        transform: scaleX(1);
      }
      .site-header__search {
        position: relative;
        display: flex;
        align-items: center;
      }
      .site-header__search input {
        width: 100%;
        min-width: 0;
        height: 44px;
        padding: 0 52px 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        outline: none;
        transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
      }
      .site-header__search input::placeholder {
        color: rgba(255, 255, 255, 0.58);
      }
      .site-header__search input:focus {
        border-color: rgba(242, 196, 109, 0.62);
        background: rgba(255, 255, 255, 0.16);
        box-shadow: 0 0 0 4px rgba(242, 196, 109, 0.1);
      }
      .site-header__search button,
      .site-header__actions a,
      .site-header__actions button,
      .btn,
      .btn-secondary,
      .btn-ghost {
        border: 0;
        cursor: pointer;
        text-decoration: none;
      }
      .site-header__search button {
        position: absolute;
        right: 5px;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #24253a;
        font-size: 13px;
        font-weight: 800;
      }
      .site-header__actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        position: relative;
      }
      .site-header__iconlink {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        height: 44px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
      }
      .site-header__iconlink:hover,
      .site-header__iconlink:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(242, 196, 109, 0.5);
        background: rgba(255, 255, 255, 0.16);
      }
      .site-header__count {
        position: absolute;
        top: -6px;
        right: -4px;
        display: inline-grid;
        place-items: center;
        min-width: 20px;
        height: 20px;
        padding: 0 6px;
        border-radius: 999px;
        background: var(--accent);
        color: #24253a;
        font-size: 11px;
        font-weight: 800;
      }
      .site-header__auth {
        gap: 8px;
      }
      .site-header__user-menu {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        width: 210px;
        padding: 10px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(32, 36, 49, 0.98);
        box-shadow: 0 24px 40px rgba(7, 10, 18, 0.34);
        display: none;
        gap: 6px;
      }
      .site-header__user-menu.is-open {
        display: grid;
      }
      .site-header__user-link {
        display: flex;
        align-items: center;
        min-height: 40px;
        padding: 0 12px;
        border-radius: 12px;
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        background: transparent;
      }
      .site-header__user-link:hover,
      .site-header__user-link:focus-visible {
        background: rgba(255, 255, 255, 0.08);
      }
      .site-header__avatar {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.18);
        font-size: 11px;
      }
      main {
        padding: 0 0 72px;
        animation: pageFadeUp 0.32s ease-out both;
      }
      .page-hero {
        display: grid;
        gap: 12px;
        margin-bottom: 30px;
      }
      .page-hero h1 {
        margin: 0;
        font-family: "Space Grotesk", sans-serif;
        font-size: 48px;
        line-height: 1.04;
      }
      .page-hero p {
        margin: 0;
        max-width: 720px;
        color: var(--text-soft);
        font-size: 16px;
        line-height: 1.7;
      }
      .page-breadcrumb {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
        color: var(--muted);
        font-size: 14px;
      }
      .page-breadcrumb a {
        text-decoration: none;
      }
      .section-card,
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 46px;
        padding: 0 22px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #25263b;
        font-weight: 800;
        box-shadow: 0 14px 28px rgba(242, 196, 109, 0.22);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .btn:hover,
      .btn:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 20px 34px rgba(242, 196, 109, 0.28);
      }
      .btn:active,
      .btn-secondary:active,
      .btn-ghost:active,
      button:active {
        transform: scale(0.98);
      }
      .btn.is-loading,
      .btn-ghost.is-loading,
      button.is-loading {
        pointer-events: none;
      }
      .btn.is-success,
      .btn-ghost.is-success,
      button.is-success {
        background: var(--success);
        color: #10251b;
      }
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 46px;
        padding: 0 20px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.24);
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 700;
        transition: transform 0.3s ease, background 0.3s ease;
      }
      .btn-secondary:hover,
      .btn-secondary:focus-visible {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.16);
      }
      .btn-ghost {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--primary);
        font-weight: 700;
      }
      .field {
        display: grid;
        gap: 8px;
      }
      .field label {
        color: var(--text-soft);
        font-size: 14px;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--text);
        padding: 13px 14px;
      }
      .field input.is-invalid,
      .field select.is-invalid,
      .field textarea.is-invalid {
        border-color: rgba(251, 113, 133, 0.75);
        box-shadow: 0 0 0 4px rgba(251, 113, 133, 0.1);
      }
      .field-error {
        color: var(--danger);
        font-size: 13px;
        line-height: 1.5;
      }
      .field textarea {
        min-height: 110px;
        resize: vertical;
      }
      .stack {
        display: grid;
        gap: 20px;
      }
      .muted { color: var(--muted); }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(61, 62, 91, 0.08);
        border: 1px solid rgba(61, 62, 91, 0.16);
        color: var(--primary);
        font-size: 13px;
        font-weight: 700;
      }
      .toast-stack {
        position: fixed;
        right: 18px;
        bottom: 18px;
        display: grid;
        gap: 10px;
        z-index: 60;
      }
      .toast {
        min-width: 260px;
        max-width: min(360px, calc(100vw - 36px));
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(47, 48, 72, 0.96);
        color: #fff;
        box-shadow: var(--shadow);
      }
      .toast.success { border-color: rgba(52, 211, 153, 0.35); }
      .toast.error { border-color: rgba(251, 113, 133, 0.45); }
      .ui-state {
        padding: 28px 20px;
        border-radius: 18px;
        border: 1px dashed var(--line);
        background: rgba(255, 255, 255, 0.72);
        color: var(--text-soft);
        text-align: center;
      }
      .ui-state strong {
        display: block;
        margin-bottom: 8px;
        color: var(--text);
      }
      .ui-skeleton {
        position: relative;
        overflow: hidden;
        border-radius: 16px;
        background: #eef1f8;
      }
      .ui-skeleton::after,
      .skeleton-card::after,
      .skeleton-line::after {
        content: "";
        position: absolute;
        inset: 0;
        transform: translateX(-100%);
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.58), transparent);
        animation: skeletonShimmer 1.25s ease-in-out infinite;
      }
      .ui-skeleton-row {
        min-height: 110px;
        margin: 12px 0;
      }
      .skeleton-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
      }
      .skeleton-card {
        position: relative;
        min-height: 360px;
        border-radius: 18px;
        background: #eef1f8;
        overflow: hidden;
      }
      .skeleton-card--product {
        display: grid;
        grid-template-rows: 58% 1fr;
        gap: 14px;
        padding: 16px;
      }
      .skeleton-line {
        position: relative;
        height: 16px;
        border-radius: 999px;
        background: #e2e7f2;
        overflow: hidden;
      }
      .loading-overlay {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        background: rgba(35, 36, 54, 0.48);
        backdrop-filter: blur(6px);
        z-index: 70;
      }
      .loading-chip {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: var(--primary-dark);
        color: #fff;
      }
      .loading-spin {
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 3px solid rgba(255, 255, 255, 0.18);
        border-top-color: var(--accent);
        animation: spin 0.8s linear infinite;
      }
      .site-footer {
        background: var(--primary-dark);
        color: #fff;
        padding: 0;
      }
      .site-footer__grid {
        display: grid;
        grid-template-columns: 1.25fr 0.9fr 0.95fr 1fr;
        gap: 32px;
        padding: 64px 0 0;
      }
      .site-footer h3 {
        margin: 0 0 18px;
        font-size: 17px;
      }
      .site-footer p,
      .site-footer a {
        display: block;
        margin: 0 0 10px;
        color: rgba(255, 255, 255, 0.72);
        text-decoration: none;
        line-height: 1.7;
      }
      .site-footer__brand {
        display: grid;
        gap: 16px;
      }
      .site-footer__brand-top {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .site-footer__logo {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #25263b;
        font-family: "Space Grotesk", sans-serif;
        font-weight: 700;
      }
      .site-footer__brand-name {
        font-family: "Space Grotesk", sans-serif;
        font-size: 27px;
        line-height: 1;
      }
      .site-footer__socials {
        display: flex;
        gap: 10px;
        margin-top: 8px;
      }
      .site-footer__socials a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        margin: 0;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
      }
      .site-footer__socials span {
        color: #fff;
        font-size: 13px;
        font-weight: 700;
      }
      .site-footer__copyright {
        margin-top: 46px;
        padding: 18px 0 22px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        text-align: center;
        color: rgba(255, 255, 255, 0.5);
        font-size: 13px;
      }
      .mobile-bottom-nav {
        display: none;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      @keyframes skeletonShimmer {
        to { transform: translateX(100%); }
      }
      @keyframes pageFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }
      }
      @media (max-width: 1180px) {
        .site-header__bar {
          grid-template-columns: 1fr;
          gap: 14px;
          padding: 14px 0;
        }
        .site-header__brand,
        .site-header__nav,
        .site-header__actions {
          justify-content: center;
        }
        .site-header__search {
          width: min(100%, 620px);
          margin: 0 auto;
        }
      }
      @media (max-width: 767px) {
        :root {
          --shell: min(100% - 32px, 1280px);
          --primary: #636AE8;
          --primary-dark: #2D2E45;
          --primary-deep: #202431;
          --bg: #151924;
          --bg-soft: #1b2030;
          --surface: #202431;
          --surface-tint: rgba(99, 106, 232, 0.08);
          --line: rgba(255, 255, 255, 0.08);
          --line-soft: rgba(255, 255, 255, 0.08);
          --text: #FFFFFF;
          --text-soft: rgba(255, 255, 255, 0.65);
          --muted: rgba(255, 255, 255, 0.62);
          --accent: #636AE8;
          --accent-2: #7E84FF;
        }
        body {
          background:
            radial-gradient(circle at top, rgba(99, 106, 232, 0.16), transparent 34%),
            linear-gradient(180deg, #161A24, #121620 58%, #171B25 100%);
          color: #FFFFFF;
        }
        .topbar {
          background: #232437;
        }
        .topbar__inner {
          align-items: center;
          justify-content: space-between;
          gap: 10px;
          min-height: 48px;
          padding: 7px 0 9px;
          font-size: 12px;
        }
        .topbar__contact {
          display: flex;
          flex-direction: column;
          gap: 1px;
          max-width: 182px;
          line-height: 1.25;
        }
        .topbar__contact a:first-child::before {
          content: "☎ ";
        }
        .topbar__contact a:last-child::before {
          content: "✉ ";
        }
        .topbar__links {
          display: flex;
          align-items: center;
          gap: 10px;
          white-space: nowrap;
        }
        .topbar__links a {
          font-size: 0;
        }
        .topbar__links a:first-child::after {
          content: "FAQ";
          font-size: 12px;
        }
        .topbar__links a:last-child::after {
          content: "Contact";
          font-size: 12px;
        }
        .site-header {
          background: rgba(45, 46, 69, 0.96);
          border-bottom: 1px solid rgba(255, 255, 255, 0.08);
          backdrop-filter: blur(18px);
        }
        .site-header__bar {
          grid-template-columns: 40px minmax(0, 1fr) auto;
          gap: 8px;
          min-height: 64px;
          padding: 0;
          align-items: center;
        }
        .site-header__menu {
          width: 40px;
          height: 40px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: 0;
          border: 1px solid rgba(255, 255, 255, 0.08);
          border-radius: 12px;
          background: rgba(255, 255, 255, 0.06);
          color: #FFFFFF;
          font-size: 18px;
        }
        .site-header__brand {
          min-width: 0;
          gap: 8px;
          justify-self: start;
        }
        .site-header__logo {
          width: 32px;
          height: 32px;
          border-radius: 10px;
          background: #636AE8;
          color: #11131d;
          box-shadow: none;
          font-size: 12px;
        }
        .site-header__brand strong {
          color: #FFFFFF;
          font-size: 16px;
          letter-spacing: -0.02em;
        }
        .site-header__brand span {
          display: none;
        }
        .site-header__nav,
        .site-header__search {
          display: none;
        }
        .site-header__actions {
          width: auto;
          gap: 6px;
          justify-content: flex-end;
        }
        .site-header__iconlink {
          min-width: 38px;
          width: 38px;
          height: 38px;
          padding: 0;
          border-radius: 12px;
          border-color: rgba(255, 255, 255, 0.08);
          background: rgba(255, 255, 255, 0.08);
          box-shadow: none;
        }
        .site-header__iconlink > span:first-child {
          display: none;
        }
        .site-header__iconlink::before {
          display: block;
          font-size: 16px;
          line-height: 1;
        }
        .site-header__actions > .site-header__iconlink:not(.site-header__auth)::before {
          content: "🛒";
        }
        .site-header__auth {
          min-width: 38px;
        }
        .site-header__auth::before {
          content: "◉";
        }
        .site-header__avatar {
          display: none;
        }
        .site-header__auth span:last-child {
          display: none;
        }
        .site-header__count {
          min-width: 18px;
          height: 18px;
          top: -4px;
          right: -2px;
          background: #636AE8;
          color: #11131d;
        }
        .site-header__user-menu {
          top: calc(100% + 8px);
          right: 0;
          width: 188px;
          padding: 8px;
          border-radius: 14px;
          background: rgba(32, 36, 49, 0.98);
        }
        .site-header__user-link {
          min-height: 38px;
          font-size: 12px;
        }
        main {
          padding-bottom: 98px;
        }
        .site-footer {
          background: #2D2E45;
        }
        .site-footer__grid {
          grid-template-columns: 1fr;
          gap: 26px;
          padding-top: 28px;
        }
        .site-footer h3 {
          margin-bottom: 12px;
          text-decoration: underline;
          text-underline-offset: 4px;
        }
        .site-footer p,
        .site-footer a {
          margin-bottom: 8px;
          font-size: 13px;
          text-decoration: underline;
          text-underline-offset: 4px;
        }
        .site-footer__socials a {
          width: 36px;
          height: 36px;
          border-radius: 10px;
        }
        .site-footer__copyright {
          margin-top: 24px;
          padding: 14px 0 80px;
          background: rgba(0, 0, 0, 0.12);
          font-size: 11px;
          color: rgba(255, 255, 255, 0.65);
        }
        .mobile-bottom-nav {
          position: fixed;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 80;
          display: grid;
          grid-template-columns: repeat(4, minmax(0, 1fr));
          height: 64px;
          border-top: 1px solid rgba(255, 255, 255, 0.08);
          background: #2D2E45;
        }
        .mobile-bottom-nav__item {
          position: relative;
          display: grid;
          align-content: center;
          justify-items: center;
          gap: 4px;
          color: rgba(255, 255, 255, 0.62);
          text-decoration: none;
          font-size: 11px;
          font-weight: 600;
        }
        .mobile-bottom-nav__item strong {
          font-size: 20px;
          line-height: 1;
        }
        .mobile-bottom-nav__item.is-active {
          color: #636AE8;
        }
        .mobile-bottom-nav__badge {
          position: absolute;
          top: 7px;
          right: calc(50% - 20px);
          min-width: 16px;
          height: 16px;
          padding: 0 4px;
          border-radius: 999px;
          display: grid;
          place-items: center;
          background: #F45B9B;
          color: #14111a;
          font-size: 10px;
          font-weight: 800;
        }
      }
    block head
  body
    .topbar
      .shell.topbar__inner
        .topbar__contact
          a(href="tel:+84123456789") Hotline: +84 123 456 789
          a(href="mailto:support@soundhouse.vn") support@soundhouse.vn
        .topbar__links
          a(href="/contact-faq") Hỗ trợ
          a(href="/contact-faq") Giao hàng toàn quốc
    header.site-header(data-site-header)
      .shell.site-header__bar
        button.site-header__menu(type="button" aria-label="Mở menu") ☰
        a.site-header__brand(href="/")
          .site-header__logo SH
          div
            strong SoundHouse
            span Loa Bluetooth cao cấp
        nav.site-header__nav(aria-label="Menu chính")
          a(href="/") Trang chủ
          a(href="/category") Sản phẩm
          a(href="/#brands") Thương hiệu
          a(href="/#promo") Khuyến mãi
          a(href="/contact-faq") Liên hệ
        form.site-header__search(action="/category" method="get" data-site-search)
          input(type="search" name="search" placeholder="Tìm Marshall, JBL, Harman Kardon..." value=(typeof searchKeyword !== 'undefined' ? searchKeyword : ''))
          button(type="submit" aria-label="Tìm kiếm") Tìm
        .site-header__actions
          a.site-header__iconlink(href="/cart" aria-label="Giỏ hàng")
            span Giỏ
            span.site-header__count(data-cart-count) 0
          button.site-header__iconlink.site-header__auth(type="button" aria-label="Tài khoản" data-user-trigger aria-expanded="false")
            span.site-header__avatar TK
            span Đăng nhập
          .site-header__user-menu(data-user-menu)
            a.site-header__user-link(href="/login" data-user-login) Đăng nhập
            a.site-header__user-link(href="/register" data-user-register) Tạo tài khoản
            a.site-header__user-link(href="/account" data-user-account hidden) Tài khoản của tôi
            a.site-header__user-link(href="/account/orders" data-user-orders hidden) Đơn hàng của tôi
            a.site-header__user-link(href="/account/addresses" data-user-addresses hidden) Sổ địa chỉ
            a.site-header__user-link(href="/logout" data-user-logout hidden) Đăng xuất

