doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    block title
      title SoundHouse Auth
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet")
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    )
    style.
      * { box-sizing: border-box; }
      body {
        min-height: 100vh;
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background:
          radial-gradient(900px 600px at 20% 10%, rgba(99, 106, 232, 0.12), transparent 45%),
          radial-gradient(700px 500px at 85% 85%, rgba(56, 189, 248, 0.08), transparent 40%),
          #0a0c10;
        color: #f3f4f6;
      }
      .auth-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
      }
      .auth-shell .card {
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(29, 33, 40, 0.88);
        backdrop-filter: blur(18px);
        color: #f3f4f6;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.38);
      }
      .auth-shell .card-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .auth-shell .form-control {
        background: rgba(15, 17, 22, 0.85);
        border-color: rgba(255, 255, 255, 0.12);
        color: #f3f4f6;
      }
      .auth-shell .form-control::placeholder {
        color: rgba(156, 163, 175, 0.8);
      }
      .auth-shell .form-control:focus {
        background: rgba(15, 17, 22, 0.92);
        color: #f3f4f6;
        border-color: rgba(99, 106, 232, 0.55);
        box-shadow: 0 0 0 0.25rem rgba(99, 106, 232, 0.18);
      }
      .auth-shell .text-muted,
      .auth-shell .form-text,
      .auth-shell .card-footer {
        color: #9ca3af !important;
      }
      .auth-shell a {
        text-decoration: none;
      }
  body
    .auth-shell
      block content

    script(
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    )
    block scripts
