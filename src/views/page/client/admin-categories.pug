extends ../../layouts/admin

block content
  .admin-page(data-admin-page="categories")
    .split
      .panel
        .panel__header
          .panel__title
            h3 Danh sach danh muc
            p Dong bo truc tiep voi API category hien tai.
        .admin-toolbar
          .toolbar-item.toolbar-item--grow
            input(type="search" placeholder="Tim danh muc..." data-category-search)
          .toolbar-item
            select(data-category-status)
              option(value="active") Dang hien
              option(value="inactive") Tam an
          .toolbar-actions
            button.admin-btn-secondary(type="button" data-category-refresh) Tai lai
        .list-shell
          .record-list(data-category-list)
          .empty-state(data-category-empty hidden)
            strong Chua co danh muc phu hop
            p Tao danh muc moi hoac bo loc lai du lieu.
          .pagination(data-category-pagination)
      .panel
        .panel__header
          .panel__title
            h3 Them / sua danh muc
            p Khong xoa duoc danh muc dang co san pham hoac danh muc con.
        form.stack(data-category-form novalidate)
          input(type="hidden" name="id")
          .form-section
            .field
              label(for="category-name") Ten danh muc
              input#category-name(type="text" name="name" required)
            .field
              label(for="category-parent") Danh muc cha
              select#category-parent(name="parent" data-category-parent-options)
                option(value="") Danh muc goc
            .field
              label(for="category-description") Mo ta
              textarea#category-description(name="description")
            .field-grid
              .field
                label(for="category-image") Anh / icon URL
                input#category-image(type="url" name="image")
              .field
                label(for="category-icon") Ma icon
                input#category-icon(type="text" name="icon")
            .field-grid
              .field
                label(for="category-order") Thu tu
                input#category-order(type="number" name="order" min="0" value="0")
              .field
                label(for="category-status-select") Trang thai
                select#category-status-select(name="status")
                  option(value="active") Dang hien
                  option(value="inactive") Tam an
            .field
              label(for="category-featured") Noi bat
              select#category-featured(name="featured")
                option(value="false") Khong
                option(value="true") Co
          .inline-actions
            button.admin-btn(type="submit") Luu danh muc
            button.admin-btn-ghost(type="button" data-category-reset) Lam moi
