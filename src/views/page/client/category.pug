extends ../../layouts/storefront

block head
  style.
    :root {
      --category-bg-page: #3d3e5b;
      --category-bg-topbar: rgba(0, 0, 0, 0.2);
      --category-bg-card: #1f1f2e;
      --category-bg-card-img: #1a1a28;
      --category-bg-toolbar: #1f1f2e;
      --category-bg-footer: #2d2e45;
      --category-bg-banner: #042c49;
      --category-accent: #69d4f7;
      --category-danger: #e72323;
      --category-text: #fcfcfe;
      --category-text-secondary: #c0c0d3;
      --category-text-muted: rgba(255, 255, 255, 0.6);
      --category-text-dark: #181825;
      --category-border: rgba(86, 86, 123, 0.5);
      --category-border-soft: rgba(255, 255, 255, 0.1);
      --category-star: #dee1e6;
      --category-shadow-card: 0 2px 4px rgba(11, 11, 15, 0.08);
      --category-shadow-header: 0 4px 8px rgba(11, 11, 15, 0.09);
      --category-shell: 1312px;
    }
    body {
      min-width: 1200px;
      background: var(--category-bg-page);
      color: var(--category-text);
      background-image: none;
    }
    .topbar {
      background: var(--category-bg-topbar);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .shell {
      width: min(var(--category-shell), calc(100% - 128px));
    }
    .topbar__inner {
      min-height: 35px;
      color: rgba(255, 255, 255, 0.7);
    }
    .topbar__contact,
    .topbar__links {
      gap: 20px;
    }
    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(61, 62, 91, 0.96);
      backdrop-filter: blur(14px);
      box-shadow: var(--category-shadow-header);
      border-bottom: 1px solid var(--category-border-soft);
    }
    .site-header__bar {
      min-height: 73px;
      gap: 24px;
    }
    .site-header__brand {
      min-width: 230px;
      gap: 12px;
    }
    .site-header__logo {
      width: 36px;
      height: 36px;
      border-radius: 7px;
      background: var(--category-accent);
      color: #343252;
      font-size: 14px;
      font-weight: 800;
    }
    .site-header__brand strong {
      font-family: "Be Vietnam Pro", sans-serif;
      font-size: 20px;
      color: var(--category-accent);
    }
    .site-header__search {
      flex: 0 0 575px;
      max-width: 575px;
      position: relative;
      gap: 0;
    }
    .site-header__search::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 16px;
      width: 18px;
      height: 18px;
      transform: translateY(-50%);
      border: 2px solid rgba(255, 255, 255, 0.48);
      border-radius: 50%;
      pointer-events: none;
    }
    .site-header__search::after {
      content: "";
      position: absolute;
      top: calc(50% + 5px);
      left: 30px;
      width: 7px;
      height: 2px;
      transform: rotate(45deg);
      background: rgba(255, 255, 255, 0.48);
      border-radius: 999px;
      pointer-events: none;
    }
    .site-header__search input {
      height: 39px;
      padding: 0 18px 0 44px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .site-header__search button {
      display: none;
    }
    .site-header__actions {
      margin-left: auto;
      gap: 22px;
    }
    .site-header__link {
      height: auto;
      font-size: 14px;
      color: var(--category-text);
    }
    .site-header__actions a.site-header__link:first-child,
    .site-header__actions a.site-header__link:nth-child(3) {
      color: var(--category-text-muted);
    }
    .site-header__count {
      min-width: 18px;
      height: 19px;
      background: var(--category-accent);
      color: var(--category-text-dark);
      font-size: 11px;
      font-weight: 700;
    }
    .site-header__actions a.site-header__link:last-child {
      justify-content: center;
      min-width: 77px;
      height: 40px;
      padding: 0 18px;
      border-radius: 10px;
      background: var(--category-accent);
      color: var(--category-text-dark);
      font-weight: 600;
    }
    main {
      padding: 40px 0 0;
    }
    .category-page {
      background: var(--category-bg-page);
      padding: 0 0 40px;
    }
    .category-page__breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 40px;
      color: var(--category-text-muted);
      font-size: 14px;
      line-height: 1.4;
    }
    .category-page__breadcrumb a {
      text-decoration: none;
    }
    .category-page__breadcrumb span[aria-current="page"] {
      color: var(--category-text);
    }
    .category-page__layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 972px);
      gap: 40px;
      align-items: start;
    }
    .category-sidebar {
      padding: 25px;
      background: var(--category-bg-card);
      border: 1px solid var(--category-border);
      border-radius: 14px;
      box-shadow: var(--category-shadow-card);
    }
    .category-sidebar__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 20px;
    }
    .category-sidebar__title {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 20px;
      font-weight: 700;
      line-height: 1;
    }
    .category-sidebar__title svg,
    .filter-group__toggle svg,
    .toolbar-view__button svg,
    .toolbar-filter svg,
    .toolbar-sort__icon svg,
    .pagination__button svg,
    .promo-banner__button svg,
    .card-action svg {
      width: 18px;
      height: 18px;
    }
    .category-sidebar__clear {
      border: 0;
      background: transparent;
      color: var(--category-text-secondary);
      font-size: 14px;
      cursor: pointer;
    }
    .filter-group {
      border-bottom: 1px solid var(--category-border);
    }
    .filter-group__toggle {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 18px 0 16px;
      border: 0;
      background: transparent;
      color: var(--category-text);
      font-size: 16px;
      font-weight: 600;
      text-align: left;
      cursor: pointer;
    }
    .filter-group__toggle svg {
      transition: transform 0.2s ease;
    }
    .filter-group.is-collapsed .filter-group__toggle svg {
      transform: rotate(-90deg);
    }
    .filter-group__body {
      display: grid;
      gap: 10px;
      padding: 0 0 18px;
    }
    .filter-group.is-collapsed .filter-group__body {
      display: none;
    }
    .filter-option {
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 28px;
      color: var(--category-text-secondary);
      font-size: 14px;
      line-height: 1.4;
      text-decoration: none;
    }
    .filter-option:hover,
    .filter-option.is-active {
      color: var(--category-text);
    }
    .filter-option input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .filter-option__box {
      width: 16px;
      height: 16px;
      flex: 0 0 16px;
      border: 1px solid #565682;
      border-radius: 2px;
      background: #fff;
      transition: border-color 0.2s ease, background-color 0.2s ease;
    }
    .filter-option input:checked + .filter-option__box {
      border-color: var(--category-accent);
      background: var(--category-accent);
      box-shadow: inset 0 0 0 3px #fff;
    }
    .filter-actions {
      padding-top: 24px;
    }
    .filter-actions__button,
    .promo-banner__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 0;
      border-radius: 10px;
      background: var(--category-accent);
      color: var(--category-text-dark);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s ease;
    }
    .filter-actions__button {
      width: 100%;
      height: 40px;
    }
    .filter-actions__button:hover,
    .promo-banner__button:hover,
    .card-action:hover,
    .site-header__actions a.site-header__link:last-child:hover {
      background: #8de1f9;
    }
    .category-content__hero {
      margin-bottom: 28px;
    }
    .category-content__hero h1 {
      width: 432px;
      margin: 0 0 12px;
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--category-text);
    }
    .category-content__hero p {
      width: 669px;
      margin: 0;
      color: var(--category-text-muted);
      font-size: 15px;
      line-height: 1.6;
    }
    .category-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 74px;
      margin-bottom: 32px;
      padding: 16px 17px;
      border: 1px solid var(--category-border);
      border-radius: 14px;
      background: var(--category-bg-toolbar);
      box-shadow: var(--category-shadow-card);
    }
    .category-toolbar__left,
    .category-toolbar__right {
      display: flex;
      align-items: center;
      gap: 18px;
    }
    .category-toolbar__count {
      font-size: 14px;
      color: var(--category-text-secondary);
    }
    .category-toolbar__count strong {
      margin-right: 4px;
      color: var(--category-text);
      font-weight: 600;
    }
    .toolbar-filter {
      display: none;
    }
    .toolbar-view {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px;
      border-radius: 10px;
      background: var(--category-bg-card-img);
    }
    .toolbar-view__button {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 0;
      border-radius: 10px;
      background: transparent;
      color: var(--category-text-secondary);
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .toolbar-view__button.is-active {
      background: var(--category-bg-card);
      color: var(--category-accent);
      box-shadow: var(--category-shadow-card);
    }
    .toolbar-sort {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--category-text-secondary);
      font-size: 14px;
    }
    .toolbar-sort__field {
      position: relative;
      width: 165px;
    }
    .toolbar-sort__field select {
      width: 100%;
      height: 34px;
      padding: 0 36px 0 12px;
      border-radius: 10px;
      border: 1px solid #565682;
      background: var(--category-bg-card-img);
      color: var(--category-text);
      appearance: none;
      outline: none;
    }
    .toolbar-sort__icon {
      position: absolute;
      top: 50%;
      right: 10px;
      transform: translateY(-50%);
      color: var(--category-text-secondary);
      pointer-events: none;
    }
    .catalog-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 308px));
      gap: 24px;
    }
    .catalog-grid[data-view="list"] {
      grid-template-columns: 1fr;
    }
    .catalog-grid[data-view="list"] .product-card {
      display: grid;
      grid-template-columns: 306px minmax(0, 1fr);
      height: auto;
    }
    .catalog-grid[data-view="list"] .product-card__info {
      padding: 20px 20px 20px 17px;
    }
    .catalog-grid[data-view="list"] .product-card__media {
      height: 100%;
      min-height: 306px;
    }
    .product-card {
      position: relative;
      overflow: hidden;
      min-height: 463px;
      border: 1px solid var(--category-border);
      border-radius: 12px;
      background: var(--category-bg-card);
      box-shadow: var(--category-shadow-card);
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .product-card:hover {
      transform: translateY(-2px);
      border-color: rgba(105, 212, 247, 0.4);
      box-shadow: 0 8px 24px rgba(11, 11, 15, 0.2);
    }
    .product-card__media {
      position: relative;
      height: 306px;
      background: var(--category-bg-card-img);
    }
    .product-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: var(--category-bg-card-img);
    }
    .product-card__badges {
      position: absolute;
      top: 12px;
      left: 12px;
      display: grid;
      gap: 8px;
      z-index: 2;
    }
    .product-card__badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      height: 21px;
      padding: 0 10px;
      border-radius: 11px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
    }
    .product-card__badge--new {
      background: var(--category-accent);
      color: var(--category-text-dark);
    }
    .product-card__badge--sale {
      background: var(--category-danger);
      color: #fafafa;
    }
    .product-card__overlay {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 72px;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding: 0 16px 16px;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .product-card:hover .product-card__overlay {
      opacity: 1;
    }
    .card-action {
      width: 100%;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 0;
      border-radius: 10px;
      background: var(--category-accent);
      color: var(--category-text-dark);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s ease;
    }
    .product-card__info {
      padding: 14px 17px 18px;
    }
    .product-card__brand {
      margin: 0 0 10px;
      color: var(--category-text-secondary);
      font-size: 12px;
      line-height: 1.3;
    }
    .product-card__title {
      display: -webkit-box;
      min-height: 38px;
      margin: 0 0 18px;
      overflow: hidden;
      color: var(--category-text);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.4;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .product-card__title a {
      color: inherit;
      text-decoration: none;
    }
    .product-card__rating {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 16px;
      color: var(--category-text-secondary);
      font-size: 12px;
    }
    .product-card__stars {
      display: inline-flex;
      gap: 2px;
      color: var(--category-star);
    }
    .product-card__stars svg {
      width: 12px;
      height: 12px;
    }
    .product-card__price {
      display: flex;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
    }
    .product-card__price strong {
      color: var(--category-accent);
      font-size: 20px;
      font-weight: 700;
      line-height: 1;
    }
    .product-card__price span {
      color: var(--category-text-secondary);
      font-size: 12px;
      text-decoration: line-through;
    }
    .catalog-pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin: 40px 0;
    }
    .pagination__button,
    .pagination__dots {
      width: 40px;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      border: 1px solid var(--category-border);
      background: var(--category-bg-card);
      color: var(--category-text);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: border-color 0.2s ease;
    }
    .pagination__button.is-active {
      background: var(--category-accent);
      border-color: var(--category-accent);
      color: var(--category-text-dark);
      font-weight: 600;
    }
    .pagination__button:hover:not(.is-active) {
      border-color: rgba(105, 212, 247, 0.5);
    }
    .promo-banner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      margin-top: 16px;
      padding: 33px;
      min-height: 154px;
      border: 1px solid rgba(105, 212, 247, 0.2);
      border-radius: 14px;
      background: var(--category-bg-banner);
    }
    .promo-banner__content h2 {
      margin: 0 0 12px;
      color: var(--category-text-dark);
      font-size: 24px;
      font-weight: 700;
      line-height: 1.2;
    }
    .promo-banner__content p {
      width: 705px;
      margin: 0;
      color: rgba(24, 24, 37, 0.8);
      font-size: 15px;
      line-height: 1.6;
    }
    .promo-banner__button {
      width: 166px;
      height: 44px;
      flex: 0 0 auto;
    }
    .empty-state {
      padding: 48px 32px;
      border: 1px dashed rgba(255, 255, 255, 0.18);
      border-radius: 14px;
      background: var(--category-bg-card);
      color: var(--category-text-secondary);
      text-align: center;
    }
    .site-footer {
      margin-top: 60px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      background: var(--category-bg-footer);
    }
    .site-footer .shell {
      width: min(1240px, calc(100% - 200px));
    }
    .site-footer__grid {
      padding: 65px 0 0;
      gap: 44px;
    }
    .site-footer__brand-name {
      font-family: "Be Vietnam Pro", sans-serif;
      font-size: 20px;
      font-weight: 700;
    }
    .site-footer p,
    .site-footer a {
      font-size: 14px;
      color: var(--category-text-muted);
    }
    .site-footer__bank strong,
    .site-footer h3 {
      color: var(--category-text);
    }
    .site-footer__bank span {
      display: block;
      font-size: 13px;
    }
    .site-footer__socials a {
      background: transparent;
      border-color: transparent;
      color: var(--category-text);
    }
    .site-footer__socials a:hover {
      border-color: rgba(255, 255, 255, 0.16);
    }
    .site-footer__copyright {
      padding: 18px 0 19px;
      color: rgba(255, 255, 255, 0.4);
      font-size: 12px;
    }

block content
  - const currentCategoryName = category && category.name ? category.name : 'Tat ca Loa'
  - const currentCategoryDescription = category && category.description ? category.description : 'Kham pha bo suu tap cac dong loa di dong, loa thong minh voi am thanh trung thuc tu cac thuong hieu hang dau the gioi.'
  - const currentCategorySlug = filters && filters.categorySlug ? filters.categorySlug : (category && category.slug ? category.slug : '')
  - const currentSort = filters && filters.sort ? filters.sort : 'featured'
  - const currentSearch = filters && filters.search ? filters.search : ''
  - const currentBrand = filters && filters.brand ? filters.brand : ''
  - const currentMinPrice = filters && Number(filters.minPrice) ? Number(filters.minPrice) : 0
  - const currentMaxPrice = filters && Number(filters.maxPrice) ? Number(filters.maxPrice) : 0
  - const displayProducts = products || []
  - const productCount = displayProducts.length
  - const categoryOptions = [{ slug: '', name: 'Tat ca Loa' }, { slug: 'loa-bluetooth', name: 'Loa Bluetooth' }, { slug: 'loa-karaoke', name: 'Loa Karaoke' }, { slug: 'loa-soundbar', name: 'Loa Soundbar' }, { slug: 'loa-thong-minh', name: 'Loa Thong minh' }]
  - const brandOptions = Array.from(new Set([...(brands || []), 'Marshall', 'Bose', 'JBL', 'Sony', 'Bang & Olufsen', 'Harman Kardon', 'Apple', 'Samsung']))
  - const priceOptions = [{ label: 'Duoi 2.000.000d', min: 0, max: 2000000 }, { label: '2.000.000d - 5.000.000d', min: 2000000, max: 5000000 }, { label: '5.000.000d - 10.000.000d', min: 5000000, max: 10000000 }, { label: '10.000.000d - 20.000.000d', min: 10000000, max: 20000000 }, { label: 'Tren 20.000.000d', min: 20000000, max: 0 }]
  - const activePriceKey = `${currentMinPrice || 0}-${currentMaxPrice || 0}`
  .category-page
    .shell
      nav.category-page__breadcrumb(aria-label="Breadcrumb")
        a(href="/") Trang chu
        span ›
        a(href="/category") San pham
        span ›
        span(aria-current="page")= currentCategoryName

      .category-page__layout
        aside.category-sidebar
          form#category-filter-form(method="get" action=`/category/${currentCategorySlug}` data-category-filter-form)
            .category-sidebar__header
              .category-sidebar__title
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M2 4.25h6.25V5.75H2zm8.75 0H14v1.5h-3.25zM2 7.25h3.75v1.5H2zm6.25 0H14v1.5H8.25zM2 10.25h7.25v1.5H2zm9.75 0H14v1.5h-2.25zM8.25 3a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5zm-2.5 4a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5zm4 3a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5z")
                span Bo loc
              button.category-sidebar__clear(type="button" data-clear-filters) Xoa tat ca

            input(type="hidden" name="search" value=currentSearch)
            input(type="hidden" name="sort" value=currentSort)
            input(type="hidden" name="minPrice" value=currentMinPrice)
            input(type="hidden" name="maxPrice" value=currentMaxPrice)

            .filter-group(data-filter-group)
              button.filter-group__toggle(type="button" data-filter-toggle aria-expanded="true")
                span Danh muc
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M3.31 5.32 8 10.68l4.69-5.36 1.01.88L8 12.79.3 6.2z")
              .filter-group__body
                each item in categoryOptions
                  - const isActiveCategory = (!item.slug && !currentCategorySlug) || item.slug === currentCategorySlug
                  label.filter-option(class=isActiveCategory ? 'is-active' : '')
                    input(type="radio" name="categorySlug" value=item.slug checked=isActiveCategory)
                    span.filter-option__box
                    span= item.name

            .filter-group(data-filter-group)
              button.filter-group__toggle(type="button" data-filter-toggle aria-expanded="true")
                span Thuong hieu
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M3.31 5.32 8 10.68l4.69-5.36 1.01.88L8 12.79.3 6.2z")
              .filter-group__body
                each brandName in brandOptions
                  label.filter-option(class=currentBrand === brandName ? 'is-active' : '')
                    input(type="radio" name="brand" value=brandName checked=(currentBrand === brandName))
                    span.filter-option__box
                    span= brandName

            .filter-group(data-filter-group)
              button.filter-group__toggle(type="button" data-filter-toggle aria-expanded="true")
                span Khoang gia
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M3.31 5.32 8 10.68l4.69-5.36 1.01.88L8 12.79.3 6.2z")
              .filter-group__body
                each option in priceOptions
                  - const optionKey = `${option.min}-${option.max}`
                  label.filter-option(class=activePriceKey === optionKey ? 'is-active' : '')
                    input(type="radio" name="priceRange" value=optionKey data-price-min=option.min data-price-max=option.max checked=(activePriceKey === optionKey))
                    span.filter-option__box
                    span= option.label

            .filter-actions
              button.filter-actions__button(type="submit") Ap dung bo loc

        section.category-content
          .category-content__hero
            h1= currentCategoryName
            p= currentCategoryDescription

          .category-toolbar
            .category-toolbar__left
              .category-toolbar__count
                strong= productCount
                span san pham duoc tim thay
              button.toolbar-filter(type="button" aria-label="Mo bo loc")
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M2 4.25h6.25V5.75H2zm8.75 0H14v1.5h-3.25zM2 7.25h3.75v1.5H2zm6.25 0H14v1.5H8.25zM2 10.25h7.25v1.5H2zm9.75 0H14v1.5h-2.25zM8.25 3a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5zm-2.5 4a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5zm4 3a1.75 1.75 0 110 3.5 1.75 1.75 0 010-3.5z")
              .toolbar-view(role="group" aria-label="Chuyen kieu hien thi")
                button.toolbar-view__button.is-active(type="button" data-view-toggle="grid" aria-label="Dang luoi" aria-pressed="true")
                  svg(viewBox="0 0 16 16" aria-hidden="true")
                    path(fill="currentColor" d="M2 2h5v5H2zm7 0h5v5H9zM2 9h5v5H2zm7 0h5v5H9z")
                button.toolbar-view__button(type="button" data-view-toggle="list" aria-label="Dang danh sach" aria-pressed="false")
                  svg(viewBox="0 0 16 16" aria-hidden="true")
                    path(fill="currentColor" d="M2 3h2v2H2zm3.5 0H14v2H5.5zM2 7h2v2H2zm3.5 0H14v2H5.5zM2 11h2v2H2zm3.5 0H14v2H5.5z")
            .category-toolbar__right
              .toolbar-sort
                span Sap xep theo:
                .toolbar-sort__field
                  select(form="category-filter-form" data-sort-field)
                    option(value="featured" selected=(currentSort === 'featured')) Noi bat
                    option(value="newest" selected=(currentSort === 'newest')) Moi nhat
                    option(value="price_asc" selected=(currentSort === 'price_asc')) Gia tang dan
                    option(value="price_desc" selected=(currentSort === 'price_desc')) Gia giam dan
                    option(value="rating" selected=(currentSort === 'rating')) Danh gia cao
                    option(value="name" selected=(currentSort === 'name')) Ten A-Z
                  .toolbar-sort__icon
                    svg(viewBox="0 0 16 16" aria-hidden="true")
                      path(fill="currentColor" d="M5.5 2.5 3 5h5zm5 11L13 11H8zM8.75 4.25h4.5v1.5h-4.5zm-6 6h4.5v1.5h-4.5z")

          if displayProducts.length
            .catalog-grid(data-catalog-grid data-view="grid")
              each product, index in displayProducts
                - const reviewCount = product.ratingCount || 24 + index * 11
                - const comparePrice = product.compareAtPriceText || ''
                - const primaryVariantId = product.primaryVariant && product.primaryVariant.id ? product.primaryVariant.id : ''
                article.product-card
                  .product-card__media
                    img.product-card__image(src=product.image alt=product.name loading="lazy")
                    .product-card__badges
                      if index === 0 || index === 6
                        span.product-card__badge.product-card__badge--new Moi
                      if product.discountPercentage
                        span.product-card__badge.product-card__badge--sale -#{Math.round(product.discountPercentage)}%
                    .product-card__overlay
                      button.card-action(type="button" data-category-add-cart data-product-id=product.id data-variant-id=primaryVariantId)
                        svg(viewBox="0 0 16 16" aria-hidden="true")
                          path(fill="currentColor" d="M1.33 1.33h1.8l1.02 7.03a1.33 1.33 0 0 0 1.32 1.14h6.44a1.33 1.33 0 0 0 1.3-1.03l1.04-4.8H4.06")
                          circle(fill="currentColor" cx="6" cy="13.34" r="1.34")
                          circle(fill="currentColor" cx="11.33" cy="13.34" r="1.34")
                        span Them vao gio
                  .product-card__info
                    p.product-card__brand= product.brand || 'Marshall'
                    h2.product-card__title
                      a(href=`/products/${product.slug}`)= product.name
                    .product-card__rating
                      .product-card__stars(aria-hidden="true")
                        each _ in [1, 2, 3, 4, 5]
                          svg(viewBox="0 0 12 12")
                            path(fill="currentColor" d="m6 0.85 1.39 2.82 3.11.45-2.25 2.19.53 3.09L6 7.95 3.22 9.4l.53-3.09L1.5 4.12l3.11-.45z")
                      span= `(${reviewCount})`
                    .product-card__price
                      strong= product.priceText
                      if comparePrice
                        span= comparePrice

            nav.catalog-pagination(aria-label="Phan trang")
              a.pagination__button(href="#" aria-label="Trang truoc")
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="M9.97 3.97 5.94 8l4.03 4.03-1.06 1.06L3.82 8l5.09-5.09z")
              a.pagination__button.is-active(href="#") 1
              a.pagination__button(href="#") 2
              a.pagination__button(href="#") 3
              span.pagination__dots ...
              a.pagination__button(href="#") 12
              a.pagination__button(href="#" aria-label="Trang sau")
                svg(viewBox="0 0 16 16" aria-hidden="true")
                  path(fill="currentColor" d="m6.03 3.97 1.06-1.06L12.18 8l-5.09 5.09-1.06-1.06L10.06 8z")

            .promo-banner
              .promo-banner__content
                h2 Chinh sach tra gop 0%
                p So huu ngay sieu pham am thanh chi voi 500.000d moi thang. Thu tuc xet duyet nhanh chong trong 15 phut.
              a.promo-banner__button(href="/contact-faq")
                span Tim hieu them
          else
            .empty-state
              p Khong co san pham phu hop voi bo loc hien tai.
              p Hay thu doi bo loc hoac danh muc.

block scripts
  script(type="module" src="/js/category.js")
