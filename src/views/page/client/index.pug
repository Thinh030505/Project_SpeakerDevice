extends ../../layouts/storefront

block head
  style.
    .home-page {
      overflow: hidden;
      background:
        linear-gradient(180deg, #eef0f7 0, #f8f9fc 48%, #ffffff 100%);
    }
    .home-shell {
      width: var(--shell);
      margin: 0 auto;
    }
    .home-section {
      padding: 80px 0;
    }
    .section-heading {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 34px;
    }
    .section-heading h2 {
      margin: 0 0 10px;
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 42px;
      line-height: 1.08;
      letter-spacing: 0;
      color: var(--primary-dark);
    }
    .section-heading p {
      margin: 0;
      max-width: 570px;
      color: var(--text-soft);
      line-height: 1.75;
    }
    .section-link {
      color: var(--primary);
      font-size: 14px;
      font-weight: 800;
      text-decoration: none;
      white-space: nowrap;
    }
    .home-hero {
      position: relative;
      min-height: 86vh;
      display: grid;
      align-items: center;
      padding: 58px 0 46px;
      color: #fff;
      background:
        linear-gradient(135deg, rgba(61, 62, 91, 0.98), rgba(47, 48, 72, 0.96) 48%, rgba(34, 35, 54, 0.98)),
        var(--primary);
      overflow: hidden;
      isolation: isolate;
    }
    .home-hero::before,
    .home-hero::after {
      content: "";
      position: absolute;
      pointer-events: none;
      opacity: 0.5;
    }
    .home-hero::before {
      inset: -18% -8% auto auto;
      width: 520px;
      height: 520px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(242, 196, 109, 0.34), rgba(242, 196, 109, 0) 68%);
      filter: blur(16px);
      animation: heroGlowMove 14s ease-in-out infinite;
    }
    .home-hero::after {
      left: 0;
      right: 0;
      bottom: -1px;
      height: 120px;
      background:
        linear-gradient(135deg, transparent 0 42%, rgba(255, 255, 255, 0.08) 42% 48%, transparent 48% 100%),
        linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(238, 240, 247, 0.98));
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
      gap: 54px;
      align-items: center;
    }
    .hero-copy {
      animation: fadeSlideUp 0.7s ease both;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.1);
      color: #fff2cc;
      font-size: 13px;
      font-weight: 800;
      backdrop-filter: blur(12px);
    }
    .hero-badge::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 16px rgba(242, 196, 109, 0.68);
    }
    .hero-copy h1 {
      margin: 24px 0 18px;
      max-width: 620px;
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 68px;
      line-height: 1.02;
      letter-spacing: 0;
    }
    .hero-copy p {
      margin: 0;
      max-width: 560px;
      color: rgba(255, 255, 255, 0.78);
      font-size: 17px;
      line-height: 1.85;
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 34px;
      animation: fadeSlideUp 0.75s 0.12s ease both;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 36px;
      max-width: 560px;
    }
    .hero-stat {
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(12px);
    }
    .hero-stat strong {
      display: block;
      font-size: 20px;
      font-weight: 800;
    }
    .hero-stat span {
      display: block;
      margin-top: 6px;
      color: rgba(255, 255, 255, 0.68);
      font-size: 13px;
    }
    .hero-slider {
      position: relative;
      min-height: 560px;
      animation: fadeSlideUp 0.8s 0.08s ease both;
    }
    .hero-slide {
      position: absolute;
      inset: 0;
      display: grid;
      align-items: center;
      justify-items: center;
      opacity: 0;
      pointer-events: none;
      transform: translateX(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .hero-slide.is-active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }
    .hero-product {
      position: relative;
      width: min(100%, 560px);
      min-height: 500px;
      display: grid;
      align-items: center;
      justify-items: center;
    }
    .hero-product__glow {
      position: absolute;
      width: 430px;
      height: 430px;
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(242, 196, 109, 0.34), rgba(255, 159, 90, 0.12) 44%, rgba(61, 62, 91, 0) 70%);
      filter: blur(10px);
      animation: softPulse 8s ease-in-out infinite;
    }
    .hero-product__image {
      position: relative;
      z-index: 1;
      width: min(90%, 480px);
      max-height: 430px;
      object-fit: contain;
      filter: drop-shadow(0 32px 34px rgba(20, 21, 34, 0.42));
      animation: productFloat 5.8s ease-in-out infinite;
    }
    .hero-banner-link {
      position: relative;
      z-index: 1;
      width: min(100%, 560px);
      min-height: 420px;
      display: grid;
      place-items: center;
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow: 0 32px 48px rgba(20, 21, 34, 0.32);
      background: rgba(255, 255, 255, 0.08);
    }
    .hero-banner-link img {
      width: 100%;
      height: 100%;
      min-height: 420px;
      object-fit: cover;
    }
    .hero-info-card {
      position: absolute;
      z-index: 2;
      display: grid;
      gap: 3px;
      min-width: 132px;
      padding: 13px 15px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.12);
      box-shadow: 0 18px 34px rgba(19, 20, 34, 0.18);
      backdrop-filter: blur(14px);
    }
    .hero-info-card strong {
      font-size: 15px;
      color: #fff;
    }
    .hero-info-card span {
      color: rgba(255, 255, 255, 0.68);
      font-size: 12px;
    }
    .hero-info-card--bass {
      left: 8%;
      top: 18%;
    }
    .hero-info-card--battery {
      right: 5%;
      top: 34%;
    }
    .hero-info-card--water {
      left: 12%;
      bottom: 18%;
    }
    .hero-controls {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 18px;
      z-index: 3;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }
    .hero-arrow,
    .hero-dot {
      border: 0;
      cursor: pointer;
    }
    .hero-arrow {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      font-size: 18px;
      transition: transform 0.3s ease, background 0.3s ease;
    }
    .hero-arrow:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.16);
    }
    .hero-dots {
      display: flex;
      gap: 9px;
      align-items: center;
    }
    .hero-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.32);
      transition: width 0.3s ease, background 0.3s ease;
    }
    .hero-dot.is-active {
      width: 30px;
      background: var(--accent);
    }
    .brand-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 18px;
    }
    .brand-card {
      min-height: 210px;
      display: grid;
      align-content: space-between;
      gap: 20px;
      padding: 22px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(61, 62, 91, 0.05), rgba(61, 62, 91, 0)),
        #fff;
      text-decoration: none;
      box-shadow: 0 14px 30px rgba(41, 42, 63, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .brand-card:hover {
      transform: translateY(-6px) scale(1.01);
      border-color: rgba(61, 62, 91, 0.32);
      box-shadow: 0 22px 38px rgba(41, 42, 63, 0.14);
    }
    .brand-card__mark {
      width: 58px;
      height: 58px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      background: var(--primary);
      color: #fff;
      font-family: "Space Grotesk", sans-serif;
      font-size: 18px;
      font-weight: 700;
    }
    .brand-card h3 {
      margin: 0 0 8px;
      color: var(--primary-dark);
      font-size: 23px;
      line-height: 1.18;
    }
    .brand-card p {
      margin: 0;
      color: var(--text-soft);
      font-size: 14px;
      line-height: 1.65;
    }
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
    }
    .product-card-home {
      position: relative;
      min-height: 100%;
      display: grid;
      grid-template-rows: auto 1fr;
      padding: 18px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 14px 30px rgba(41, 42, 63, 0.08);
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .product-card-home:hover {
      transform: translateY(-6px);
      border-color: rgba(61, 62, 91, 0.28);
      box-shadow: 0 24px 42px rgba(41, 42, 63, 0.16);
    }
    .product-card-home__media {
      position: relative;
      height: 250px;
      display: grid;
      place-items: center;
      margin-bottom: 18px;
      border-radius: 15px;
      background:
        radial-gradient(circle at center, rgba(61, 62, 91, 0.12), rgba(61, 62, 91, 0.04) 56%, rgba(61, 62, 91, 0.02)),
        #f3f4f9;
      overflow: hidden;
    }
    .product-card-home__media img {
      width: 82%;
      height: 210px;
      object-fit: contain;
      transition: transform 0.3s ease;
      filter: drop-shadow(0 16px 18px rgba(41, 42, 63, 0.14));
    }
    .product-card-home:hover .product-card-home__media img {
      transform: scale(1.03);
    }
    .product-card-home__tag {
      position: absolute;
      left: 14px;
      top: 14px;
      padding: 7px 11px;
      border-radius: 999px;
      background: var(--accent);
      color: #2f3048;
      font-size: 12px;
      font-weight: 800;
    }
    .product-card-home__quick {
      position: absolute;
      left: 16px;
      right: 16px;
      bottom: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 40px;
      border-radius: 999px;
      background: rgba(61, 62, 91, 0.94);
      color: #fff;
      font-size: 13px;
      font-weight: 800;
      text-decoration: none;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .product-card-home:hover .product-card-home__quick {
      opacity: 1;
      transform: translateY(0);
    }
    .product-card-home__body {
      display: grid;
      grid-template-rows: auto auto auto 1fr auto;
      gap: 11px;
    }
    .product-card-home__brand {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .product-card-home__body h3 {
      min-height: 48px;
      margin: 0;
      color: var(--primary-dark);
      font-size: 18px;
      line-height: 1.35;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }
    .product-card-home__body a {
      color: inherit;
      text-decoration: none;
    }
    .product-card-home__rating {
      color: var(--text-soft);
      font-size: 13px;
    }
    .product-card-home__price {
      display: flex;
      align-items: center;
      gap: 9px;
      flex-wrap: wrap;
    }
    .product-card-home__price strong {
      color: var(--primary);
      font-size: 22px;
      font-weight: 800;
    }
    .product-card-home__compare {
      color: var(--muted);
      font-size: 14px;
      text-decoration: line-through;
    }
    .product-card-home__button {
      width: 100%;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-top: 6px;
      border: 0;
      border-radius: 999px;
      background: var(--primary);
      color: #fff;
      font-weight: 800;
      text-decoration: none;
      transition: transform 0.3s ease, background 0.3s ease;
    }
    .product-card-home__button:hover {
      transform: translateY(-2px);
      background: var(--primary-dark);
    }
    .trend-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }
    .trend-card {
      position: relative;
      min-height: 360px;
      display: grid;
      align-content: end;
      padding: 26px;
      border-radius: 22px;
      color: #fff;
      overflow: hidden;
      background: var(--primary);
      box-shadow: 0 20px 42px rgba(41, 42, 63, 0.16);
      text-decoration: none;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .trend-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 28px 52px rgba(41, 42, 63, 0.22);
    }
    .trend-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(61, 62, 91, 0.12), rgba(20, 21, 36, 0.88)),
        radial-gradient(circle at 72% 18%, rgba(242, 196, 109, 0.32), rgba(242, 196, 109, 0) 36%);
      z-index: 1;
    }
    .trend-card img {
      position: absolute;
      inset: 24px 24px auto auto;
      width: min(58%, 230px);
      height: 190px;
      object-fit: contain;
      filter: drop-shadow(0 18px 18px rgba(0, 0, 0, 0.22));
      z-index: 0;
      transition: transform 0.3s ease;
    }
    .trend-card:hover img {
      transform: scale(1.03);
    }
    .trend-card__content {
      position: relative;
      z-index: 2;
      max-width: 300px;
    }
    .trend-card__content span {
      display: inline-flex;
      margin-bottom: 12px;
      color: #ffe2a0;
      font-size: 13px;
      font-weight: 800;
    }
    .trend-card__content h3 {
      margin: 0 0 10px;
      font-size: 26px;
      line-height: 1.18;
    }
    .trend-card__content p {
      margin: 0 0 18px;
      color: rgba(255, 255, 255, 0.76);
      line-height: 1.7;
    }
    .trend-card__cta {
      display: inline-flex;
      color: #fff;
      font-size: 14px;
      font-weight: 800;
    }
    .promo-banner {
      position: relative;
      border-radius: 26px;
      padding: 48px;
      color: #fff;
      background:
        linear-gradient(135deg, rgba(61, 62, 91, 0.98), rgba(47, 48, 72, 0.98)),
        var(--primary);
      box-shadow: 0 24px 54px rgba(41, 42, 63, 0.22);
      overflow: hidden;
    }
    .promo-banner::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 2px, transparent 2px 24px);
      mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0));
      opacity: 0.42;
    }
    .promo-banner::after {
      content: "";
      position: absolute;
      right: -80px;
      top: -90px;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(242, 196, 109, 0.32), rgba(242, 196, 109, 0));
      filter: blur(14px);
    }
    .promo-banner__inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 28px;
      align-items: center;
    }
    .promo-banner h2 {
      margin: 0 0 12px;
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 44px;
      line-height: 1.08;
      letter-spacing: 0;
    }
    .promo-banner p {
      margin: 0;
      max-width: 620px;
      color: rgba(255, 255, 255, 0.78);
      font-size: 16px;
      line-height: 1.75;
    }
    .newsletter-band {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: center;
      padding: 34px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 16px 34px rgba(41, 42, 63, 0.08);
    }
    .newsletter-band h2 {
      margin: 0 0 10px;
      color: var(--primary-dark);
      font-size: 30px;
      line-height: 1.2;
    }
    .newsletter-band p {
      margin: 0;
      color: var(--text-soft);
      line-height: 1.7;
    }
    .newsletter-band__form {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .newsletter-band__form input {
      width: min(340px, 100%);
      height: 48px;
      padding: 0 16px;
      border-radius: 999px;
      border: 1px solid var(--line);
      color: var(--text);
      outline: none;
    }
    .newsletter-band__form input:focus {
      border-color: rgba(61, 62, 91, 0.42);
      box-shadow: 0 0 0 4px rgba(61, 62, 91, 0.08);
    }
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes productFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }
    @keyframes softPulse {
      0%, 100% { transform: scale(0.96); opacity: 0.75; }
      50% { transform: scale(1.04); opacity: 1; }
    }
    @keyframes heroGlowMove {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(-34px, 28px, 0); }
    }
    @media (max-width: 1100px) {
      .home-section {
        padding: 64px 0;
      }
      .hero-grid {
        grid-template-columns: 1fr;
        gap: 28px;
      }
      .home-hero {
        min-height: auto;
        padding: 54px 0;
      }
      .hero-copy h1 {
        font-size: 56px;
      }
      .hero-slider {
        min-height: 500px;
      }
      .brand-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .trend-grid,
      .promo-banner__inner,
      .newsletter-band {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 720px) {
      .home-section {
        padding: 48px 0;
      }
      .section-heading {
        align-items: flex-start;
        flex-direction: column;
      }
      .section-heading h2 {
        font-size: 32px;
      }
      .hero-copy h1 {
        font-size: 40px;
      }
      .hero-copy p {
        font-size: 15px;
      }
      .hero-stats,
      .brand-grid,
      .product-grid,
      .trend-grid {
        grid-template-columns: 1fr;
      }
      .hero-slider {
        min-height: 430px;
      }
      .hero-product {
        min-height: 390px;
      }
      .hero-product__image {
        width: 86%;
        max-height: 300px;
      }
      .hero-product__glow {
        width: 300px;
        height: 300px;
      }
      .hero-info-card {
        min-width: 112px;
        padding: 10px 12px;
      }
      .hero-info-card--bass {
        left: 0;
        top: 12%;
      }
      .hero-info-card--battery {
        right: 0;
        top: 28%;
      }
      .hero-info-card--water {
        left: 4%;
        bottom: 12%;
      }
      .product-card-home__media {
        height: 230px;
      }
      .trend-card {
        min-height: 320px;
      }
      .promo-banner {
        padding: 30px 22px;
      }
      .promo-banner h2 {
        font-size: 32px;
      }
      .newsletter-band {
        padding: 24px 18px;
      }
      .newsletter-band__form {
        justify-content: stretch;
      }
      .newsletter-band__form input,
      .newsletter-band__form button {
        width: 100%;
      }
    }

block content
  - const bannerSlides = typeof heroBanners !== 'undefined' && heroBanners.length ? heroBanners : []
  - const heroSlides = bannerSlides.length ? bannerSlides : (featuredProducts && featuredProducts.length ? featuredProducts.slice(0, 4) : [heroProduct])
  - const useBannerSlides = bannerSlides.length > 0
  - const trendProducts = featuredProducts && featuredProducts.length ? featuredProducts.slice(0, 3) : [heroProduct, heroProduct, heroProduct]
  - const brandCards = [{ name: 'Marshall', mark: 'M', copy: 'Chất âm rock mạnh mẽ, thiết kế vintage cao cấp.' }, { name: 'JBL', mark: 'JBL', copy: 'Âm thanh sôi động, pin bền, phù hợp di chuyển.' }, { name: 'Harman Kardon', mark: 'HK', copy: 'Thiết kế sang trọng cho phòng khách hiện đại.' }, { name: 'Bose', mark: 'B', copy: 'Âm thanh cân bằng, chi tiết và dễ nghe lâu.' }, { name: 'Sony', mark: 'S', copy: 'Công nghệ hiện đại, bass chắc và kết nối ổn định.' }]
  - const trendCards = [{ title: 'Loa di động cho dã ngoại', text: 'Gọn nhẹ, pin lâu, kết nối nhanh cho những chuyến đi cuối tuần.', label: 'Di động', product: trendProducts[0] }, { title: 'Loa phòng khách cao cấp', text: 'Thiết kế nổi bật, âm trường rộng và đủ tinh tế cho không gian sống.', label: 'Phòng khách', product: trendProducts[1] || trendProducts[0] }, { title: 'Loa tiệc công suất lớn', text: 'Bass mạnh, âm lượng lớn, tạo không khí cho các buổi gặp gỡ.', label: 'Tiệc', product: trendProducts[2] || trendProducts[0] }]
  .home-page
    section.home-hero
      .home-shell.hero-grid
        .hero-copy
          .hero-badge Âm thanh sống động
          h1 Nâng tầm không gian âm nhạc của bạn
          p Khám phá các mẫu loa Bluetooth cao cấp từ Marshall, JBL, Harman Kardon, Bose và Sony.
          .hero-actions
            a.btn(href="/category") Mua ngay
            a.btn-secondary(href="/category") Khám phá sản phẩm
          .hero-stats
            .hero-stat
              strong 5+
              span Thương hiệu cao cấp
            .hero-stat
              strong 24h
              span Hỗ trợ tư vấn nhanh
            .hero-stat
              strong 100%
              span Sản phẩm chính hãng
        .hero-slider(data-hero-stage)
          each product, index in heroSlides
            article.hero-slide(class=index === 0 ? 'is-active' : '' data-hero-slide aria-hidden=index === 0 ? 'false' : 'true')
              .hero-product
                .hero-product__glow
                img.hero-product__image(src=product.image alt=product.name loading=index === 0 ? 'eager' : 'lazy')
                .hero-info-card.hero-info-card--bass
                  strong Bass mạnh
                  span Âm trầm sâu
                .hero-info-card.hero-info-card--battery
                  strong Pin lâu
                  span Nghe cả ngày
                .hero-info-card.hero-info-card--water
                  strong Chống nước
                  span Linh hoạt sử dụng
          .hero-controls
            button.hero-arrow(type="button" data-hero-prev aria-label="Slide trước") ‹
            .hero-dots(data-hero-dots)
              each product, index in heroSlides
                button.hero-dot(type="button" class=index === 0 ? 'is-active' : '' data-hero-dot data-slide-to=index aria-label=`Chuyển đến slide ${index + 1}`)
            button.hero-arrow(type="button" data-hero-next aria-label="Slide sau") ›

    section.home-section#brands
      .home-shell
        .section-heading
          div
            h2 Khám phá theo thương hiệu
            p Chọn nhanh phong cách âm thanh phù hợp: cổ điển, năng động, sang trọng hay công nghệ hiện đại.
          a.section-link(href="/category") Xem tất cả
        .brand-grid
          each brand in brandCards
            a.brand-card(href=`/category?brand=${encodeURIComponent(brand.name)}`)
              .brand-card__mark= brand.mark
              div
                h3= brand.name
                p= brand.copy

    section.home-section
      .home-shell
        .section-heading
          div
            h2 Sản phẩm nổi bật
            p Những mẫu loa được chọn lọc từ danh mục hiện có, hiển thị cân đối để khách hàng dễ so sánh và mua nhanh.
          a.section-link(href="/category") Xem thêm sản phẩm
        .product-grid
          each product in featuredProducts.slice(0, 8)
            article.product-card-home
              .product-card-home__media
                a(href=`/products/${product.slug}`)
                  img(src=product.image alt=product.name loading="lazy")
                if product.discountPercentage
                  span.product-card-home__tag= `-${product.discountPercentage}%`
                else if product.featured
                  span.product-card-home__tag Nổi bật
                a.product-card-home__quick(href=`/products/${product.slug}`) Xem chi tiết
              .product-card-home__body
                span.product-card-home__brand= product.brand || 'SoundHouse'
                h3
                  a(href=`/products/${product.slug}`)= product.name
                .product-card-home__rating= product.ratingText || 'Chưa có đánh giá'
                .product-card-home__price
                  strong= product.priceText
                  if product.compareAtPriceText
                    span.product-card-home__compare= product.compareAtPriceText
                if product.primaryVariant && product.isInStock
                  button.product-card-home__button(
                    type="button"
                    data-home-add-cart
                    data-product-id=product.id
                    data-variant-id=product.primaryVariant.id
                    aria-label=`Thêm ${product.name} vào giỏ`
                  ) Thêm vào giỏ
                else
                  a.product-card-home__button(href=`/products/${product.slug}` aria-label=`Xem ${product.name}`) Xem chi tiết

    section.home-section
      .home-shell
        .section-heading
          div
            h2 Xu hướng âm nhạc hiện đại
            p Các lựa chọn nổi bật cho nhiều không gian sử dụng, từ phòng khách sang trọng đến những buổi tiệc ngoài trời.
          a.section-link(href="/category") Khám phá xu hướng
        .trend-grid
          each trend in trendCards
            a.trend-card(href=`/products/${trend.product.slug}`)
              img(src=trend.product.image alt=trend.product.name loading="lazy")
              .trend-card__content
                span= trend.label
                h3= trend.title
                p= trend.text
                .trend-card__cta Xem ngay

    section.home-section#promo
      .home-shell
        .promo-banner
          .promo-banner__inner
            div
              h2 Ưu đãi loa Bluetooth cao cấp
              p Giảm đến 30% cho các sản phẩm được yêu thích trong tháng này.
            a.btn(href="/category") Xem khuyến mãi

    section.home-section
      .home-shell
        .newsletter-band
          div
            h2 Nhận thông tin sản phẩm mới
            p Đăng ký để nhận ưu đãi sớm và gợi ý loa phù hợp với không gian nghe nhạc của bạn.
          form.newsletter-band__form(data-newsletter-form)
            input(type="email" name="email" placeholder="Nhập email của bạn")
            button.btn(type="submit") Đăng ký

block scripts
  script(type="module" src="/js/home.js")
