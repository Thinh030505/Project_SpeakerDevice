        section#cf-contact.cf-contact(aria-labelledby="cf-contact-title")
          .cf-form-card
            h2#cf-contact-title.cf-form-h Gửi tin nhắn cho chúng tôi
            p.cf-form-sub Để lại thông tin, chuyên viên của chúng tôi sẽ gọi lại tư vấn cho bạn sau ít phút.
            form#cf-form.cf-form(autocomplete="on" novalidate)
              .cf-frow
                .cf-fgrp
                  label.cf-flab(for="cf-name") Họ và tên
                  input#cf-name.cf-fin.cf-fin-half(type="text" name="name" placeholder="Nguyễn Văn A" required)
                .cf-fgrp
                  label.cf-flab(for="cf-email") Thư điện tử
                  input#cf-email.cf-fin.cf-fin-half(type="email" name="email" placeholder="a.nguyen@email.com" required)
              div
                label.cf-flab(for="cf-subject") Chủ đề
                input#cf-subject.cf-fin.cf-fin-full(type="text" name="subject" placeholder="Cần tư vấn loa phòng họp / Bảo hành sản phẩm...")
              div(style="margin-top:16px")
                label.cf-flab(for="cf-msg") Nội dung
                textarea#cf-msg.cf-ta(name="message" placeholder="Mô tả chi tiết nhu cầu của bạn để chúng tôi hỗ trợ tốt nhất...")
              button.cf-submit(type="submit")
                span Gửi yêu cầu ngay
                svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
