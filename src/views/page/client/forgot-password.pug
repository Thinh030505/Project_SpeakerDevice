doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Quen mat khau - SoundHouse
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet")
    style.
      :root {
        --auth-card: rgba(29, 33, 40, 0.82);
        --auth-border: rgba(255, 255, 255, 0.08);
        --auth-input-bg: rgba(15, 17, 22, 0.85);
        --auth-input-border: rgba(255, 255, 255, 0.12);
        --auth-text: #f3f4f6;
        --auth-muted: #9ca3af;
        --auth-link: #38bdf8;
        --auth-glow: rgba(56, 189, 248, 0.35);
        --auth-gradient: linear-gradient(135deg, #636ae8 0%, #38bdf8 100%);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        min-height: 100vh;
        font-family: Inter, system-ui, sans-serif;
        background: radial-gradient(900px 600px at 15% 15%, rgba(56, 189, 248, 0.12), transparent 45%), #0a0c10;
        color: var(--auth-text);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 20px;
      }
      .auth-wrap { width: 100%; max-width: 440px; }
      .auth-card {
        position: relative;
        border-radius: 14px;
        padding: 36px 32px 32px;
        background: var(--auth-card);
        border: 1px solid var(--auth-border);
        backdrop-filter: blur(18px);
        box-shadow: -6px 0 36px var(--auth-glow), 0 24px 48px rgba(0, 0, 0, 0.45);
      }
      .auth-h1 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
      .auth-sub { font-size: 14px; color: var(--auth-muted); margin-bottom: 24px; line-height: 1.6; }
      .auth-field { margin-bottom: 18px; }
      .auth-label { display:block; font-size:13px; color:var(--auth-muted); margin-bottom:8px; }
      .auth-input {
        width:100%; height:46px; padding:0 14px; border-radius:8px; border:1px solid var(--auth-input-border);
        background:var(--auth-input-bg); color:var(--auth-text); outline:none;
      }
      .auth-btn {
        width:100%; height:48px; border:0; border-radius:8px; background:var(--auth-gradient); color:#fff;
        font-size:15px; font-weight:600; cursor:pointer;
      }
      .auth-btn:disabled { opacity: .65; cursor: not-allowed; }
      .auth-switch { text-align:center; margin-top:20px; color:var(--auth-muted); font-size:14px; }
      .auth-switch a { color:var(--auth-link); text-decoration:none; }
      .alert-shell { display:grid; gap:12px; margin-bottom:16px; }

  body
    .auth-wrap
      .auth-card
        h1.auth-h1 Quen mat khau
        p.auth-sub Nhap email da dang ky. Neu tai khoan ton tai, he thong se gui ma khoi phuc 6 chu so de ban dat lai mat khau.
        #alert-container.alert-shell
        form#forgotPasswordForm
          .auth-field
            label.auth-label(for="email") Thu dien tu
            input#email.auth-input(type="email" name="email" placeholder="nguyenvana@gmail.com" required)
          button.auth-btn(type="submit" id="submitBtn") Gui ma khoi phuc
        p.auth-switch
          a(href="/login") Quay lai dang nhap

    script(type="module" src="/js/auth-pages.js")
