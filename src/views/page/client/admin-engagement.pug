extends ../../layouts/admin

block content
  .admin-page(data-admin-page="engagement")
    .admin-grid
      .panel(style="grid-column: span 7")
        .panel__header
          .panel__title
            h3 Contact inbox
            p Theo doi va cap nhat trang thai xu ly lien he tu website.
        .admin-toolbar
          .toolbar-item.toolbar-item--grow
            input(type="search" placeholder="Tim contact..." data-contact-search)
          .toolbar-item
            select(data-contact-status)
              option(value="") Tat ca
              option(value="new") Moi
              option(value="reviewed") Da xem
              option(value="resolved") Da xu ly
          .toolbar-actions
            button.admin-btn-secondary(type="button" data-contact-refresh) Tai lai
        .record-list(data-contact-list)
        .empty-state(data-contact-empty hidden)
          strong Chua co lien he nao
          p Inbox hien khong co ban ghi phu hop.
      .panel(style="grid-column: span 5")
        .panel__header
          .panel__title
            h3 Newsletter subscribers
            p Quan ly danh sach nhan ban tin va trang thai dang ky.
        .admin-toolbar
          .toolbar-item.toolbar-item--grow
            input(type="search" placeholder="Tim email..." data-subscriber-search)
          .toolbar-item
            select(data-subscriber-status)
              option(value="") Tat ca
              option(value="active") Dang nhan tin
              option(value="unsubscribed") Da huy
          .toolbar-actions
            button.admin-btn-secondary(type="button" data-subscriber-refresh) Tai lai
        .record-list(data-subscriber-list)
        .empty-state(data-subscriber-empty hidden)
          strong Chua co subscriber nao
          p Danh sach dang trong hoac khong khop bo loc.
