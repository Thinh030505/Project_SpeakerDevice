extends ../../layouts/storefront

block head
  style.
    .product-detail-page {
      background:
        linear-gradient(180deg, rgba(61, 62, 91, 0.08), rgba(61, 62, 91, 0) 360px),
        #f7f8fc;
      padding: 36px 0 0;
    }
    .product-shell {
      width: var(--shell);
      margin: 0 auto;
    }
    .product-breadcrumb {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 9px;
      margin-bottom: 24px;
      color: var(--muted);
      font-size: 14px;
    }
    .product-breadcrumb a {
      color: var(--primary);
      font-weight: 700;
      text-decoration: none;
    }
    .product-main {
      display: grid;
      grid-template-columns: minmax(0, 55fr) minmax(390px, 45fr);
      gap: 44px;
      align-items: start;
      padding: 42px;
      border-radius: 26px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 22px 54px rgba(41, 42, 63, 0.1);
      animation: detailReveal 0.55s ease both;
    }
    .product-gallery {
      min-width: 0;
    }
    .product-gallery__stage {
      position: relative;
      display: grid;
      place-items: center;
      min-height: 560px;
      border-radius: 24px;
      background:
        radial-gradient(circle at 50% 35%, rgba(61, 62, 91, 0.12), rgba(61, 62, 91, 0.04) 58%, rgba(61, 62, 91, 0.02)),
        #f4f5fa;
      box-shadow: inset 0 0 0 1px rgba(61, 62, 91, 0.06);
      overflow: hidden;
    }
    .product-gallery__stage::after {
      content: "";
      position: absolute;
      inset: auto 10% 42px;
      height: 24px;
      border-radius: 50%;
      background: rgba(38, 39, 61, 0.16);
      filter: blur(18px);
    }
    .product-gallery__image {
      position: relative;
      z-index: 1;
      width: min(86%, 560px);
      max-height: 500px;
      object-fit: contain;
      filter: drop-shadow(0 24px 28px rgba(41, 42, 63, 0.14));
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .product-gallery__stage:hover .product-gallery__image {
      transform: scale(1.05);
    }
    .product-gallery__image.is-fading {
      opacity: 0;
    }
    .product-gallery__thumbs {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(86px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .product-gallery__thumb {
      height: 88px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(61, 62, 91, 0.12);
      border-radius: 16px;
      background: #fff;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .product-gallery__thumb:hover,
    .product-gallery__thumb.is-active {
      transform: translateY(-2px);
      border-color: rgba(61, 62, 91, 0.42);
      box-shadow: 0 14px 26px rgba(41, 42, 63, 0.1);
    }
    .product-gallery__thumb img {
      width: 76%;
      height: 72px;
      object-fit: contain;
    }
    .product-info {
      position: sticky;
      top: 112px;
      min-width: 0;
    }
    .product-info__brandline {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
    }
    .product-tag {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(61, 62, 91, 0.08);
      color: var(--primary);
      font-size: 13px;
      font-weight: 800;
    }
    .product-tag--accent {
      background: rgba(242, 196, 109, 0.28);
      color: #7a5410;
    }
    .product-info h1 {
      margin: 0;
      color: var(--primary-dark);
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 42px;
      line-height: 1.12;
      letter-spacing: 0;
    }
    .product-rating {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      margin: 16px 0 0;
      color: var(--text-soft);
      font-size: 14px;
    }
    .product-rating__stars {
      color: #f2b84b;
      letter-spacing: 1px;
    }
    .product-price {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 12px;
      margin: 24px 0 16px;
    }
    .product-price strong {
      color: var(--primary);
      font-size: 36px;
      font-weight: 800;
    }
    .product-price span {
      color: var(--muted);
      font-size: 18px;
      text-decoration: line-through;
    }
    .product-summary {
      margin: 0;
      color: var(--text-soft);
      font-size: 16px;
      line-height: 1.8;
    }
    .product-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.12);
      color: #10734f;
      font-size: 14px;
      font-weight: 800;
    }
    .product-status.is-out {
      background: rgba(251, 113, 133, 0.12);
      color: #a92c44;
    }
    .product-option {
      margin-top: 26px;
      padding-top: 24px;
      border-top: 1px solid rgba(61, 62, 91, 0.12);
    }
    .product-option__head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
      color: var(--primary-dark);
      font-weight: 800;
    }
    .product-option__selected {
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
      text-align: right;
    }
    .variant-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .variant-chip {
      min-height: 42px;
      padding: 0 15px;
      border: 1px solid rgba(61, 62, 91, 0.16);
      border-radius: 999px;
      background: #fff;
      color: var(--primary);
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
      transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
    }
    .variant-chip:hover {
      transform: translateY(-2px);
      border-color: rgba(61, 62, 91, 0.36);
      box-shadow: 0 10px 20px rgba(41, 42, 63, 0.08);
    }
    .variant-chip.is-active {
      border-color: var(--primary);
      background: var(--primary);
      color: #fff;
    }
    .variant-chip:disabled {
      cursor: not-allowed;
      opacity: 0.45;
    }
    .qty-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      margin-top: 24px;
    }
    .qty-row label {
      color: var(--primary-dark);
      font-weight: 800;
    }
    .qty-box {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      padding: 7px;
      border: 1px solid rgba(61, 62, 91, 0.16);
      border-radius: 999px;
      background: #fff;
    }
    .qty-box button {
      width: 36px;
      height: 36px;
      border: 0;
      border-radius: 50%;
      background: rgba(61, 62, 91, 0.08);
      color: var(--primary);
      cursor: pointer;
      font-size: 18px;
      font-weight: 800;
      transition: transform 0.3s ease, background 0.3s ease;
    }
    .qty-box button:hover {
      transform: scale(1.03);
      background: rgba(61, 62, 91, 0.14);
    }
    .qty-box strong {
      min-width: 28px;
      text-align: center;
      color: var(--primary-dark);
    }
    .product-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 24px;
    }
    .product-action {
      min-height: 50px;
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 800;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    }
    .product-action:hover {
      transform: translateY(-2px);
    }
    .product-action:disabled {
      cursor: not-allowed;
      opacity: 0.55;
      transform: none;
      box-shadow: none;
    }
    .product-action--cart {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 16px 28px rgba(61, 62, 91, 0.22);
    }
    .product-action--cart:hover {
      background: var(--primary-dark);
      box-shadow: 0 22px 34px rgba(61, 62, 91, 0.28);
    }
    .product-action--buy {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #2f3048;
      box-shadow: 0 16px 28px rgba(242, 196, 109, 0.24);
    }
    .product-benefits {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 22px;
    }
    .product-benefit {
      padding: 13px;
      border-radius: 14px;
      background: rgba(61, 62, 91, 0.06);
      color: var(--text-soft);
      font-size: 13px;
      line-height: 1.5;
    }
    .product-benefit strong {
      display: block;
      margin-bottom: 4px;
      color: var(--primary-dark);
      font-size: 14px;
    }
    .product-section {
      margin-top: 34px;
      padding: 34px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 16px 34px rgba(41, 42, 63, 0.08);
      animation: detailReveal 0.55s ease both;
    }
    .product-section h2 {
      margin: 0 0 18px;
      color: var(--primary-dark);
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 30px;
      line-height: 1.16;
      letter-spacing: 0;
    }
    .product-description__content {
      color: var(--text-soft);
      line-height: 1.85;
      white-space: pre-line;
    }
    .product-description__bullets {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 22px;
    }
    .product-description__bullets span {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(61, 62, 91, 0.06);
      color: var(--primary-dark);
      font-weight: 800;
    }
    .spec-table {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border: 1px solid rgba(61, 62, 91, 0.12);
      border-radius: 18px;
      overflow: hidden;
    }
    .spec-row {
      display: grid;
      grid-template-columns: minmax(120px, 0.8fr) 1.2fr;
      gap: 14px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(61, 62, 91, 0.1);
      background: #fff;
    }
    .spec-row:nth-child(4n + 2),
    .spec-row:nth-child(4n + 3) {
      background: rgba(61, 62, 91, 0.04);
    }
    .spec-row:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
    .spec-row span {
      color: var(--muted);
      font-weight: 700;
    }
    .spec-row strong {
      color: var(--primary-dark);
      font-weight: 800;
    }
    .review-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
      align-items: start;
    }
    .review-list {
      display: grid;
      gap: 14px;
    }
    .review-item {
      padding: 16px;
      border-radius: 16px;
      background: rgba(61, 62, 91, 0.05);
      border: 1px solid rgba(61, 62, 91, 0.1);
    }
    .review-item__head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
      color: var(--primary-dark);
    }
    .review-stars {
      color: #f2b84b;
      letter-spacing: 2px;
    }
    .review-form {
      display: grid;
      gap: 14px;
      padding: 18px;
      border-radius: 18px;
      background: rgba(61, 62, 91, 0.05);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 22px;
    }
    .related-card {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #fff;
      color: inherit;
      text-decoration: none;
      box-shadow: 0 12px 26px rgba(41, 42, 63, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .related-card:hover {
      transform: translateY(-5px);
      border-color: rgba(61, 62, 91, 0.3);
      box-shadow: 0 20px 36px rgba(41, 42, 63, 0.14);
    }
    .related-card__media {
      height: 190px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: #f4f5fa;
      overflow: hidden;
    }
    .related-card__media img {
      width: 82%;
      height: 160px;
      object-fit: contain;
      transition: transform 0.3s ease;
    }
    .related-card:hover img {
      transform: scale(1.03);
    }
    .related-card__body {
      display: grid;
      gap: 8px;
      padding-top: 14px;
    }
    .related-card__body h3 {
      min-height: 46px;
      margin: 0;
      color: var(--primary-dark);
      font-size: 16px;
      line-height: 1.42;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }
    .related-card__brand {
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }
    .related-card__price {
      color: var(--primary);
      font-size: 18px;
      font-weight: 800;
    }
    .mobile-buy-bar {
      display: none;
    }
    @keyframes detailReveal {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 1100px) {
      .product-main {
        grid-template-columns: minmax(0, 1fr) minmax(340px, 1fr);
        gap: 32px;
        padding: 30px;
      }
      .product-gallery__stage {
        min-height: 470px;
      }
      .product-info h1 {
        font-size: 34px;
      }
      .product-price strong {
        font-size: 30px;
      }
      .product-benefits,
      .product-description__bullets {
        grid-template-columns: 1fr;
      }
      .related-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 820px) {
      .product-detail-page {
        padding-top: 24px;
      }
      .product-main,
      .review-layout,
      .spec-table {
        grid-template-columns: 1fr;
      }
      .product-main {
        padding: 18px;
        border-radius: 20px;
      }
      .product-info {
        position: static;
      }
      .product-gallery__stage {
        min-height: 360px;
      }
      .product-gallery__image {
        max-height: 320px;
      }
      .product-gallery__thumbs {
        display: flex;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
      }
      .product-gallery__thumbs::-webkit-scrollbar {
        display: none;
      }
      .product-gallery__thumb {
        flex: 0 0 88px;
      }
      .product-actions {
        grid-template-columns: 1fr;
      }
      .product-section {
        padding: 24px 18px;
      }
      .spec-row:nth-child(n) {
        background: #fff;
      }
      .spec-row:nth-child(even) {
        background: rgba(61, 62, 91, 0.04);
      }
      .spec-row:nth-last-child(-n + 2) {
        border-bottom: 1px solid rgba(61, 62, 91, 0.1);
      }
      .spec-row:last-child {
        border-bottom: 0;
      }
      .related-grid {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 6px;
        scroll-snap-type: x proximity;
      }
      .related-card {
        flex: 0 0 78%;
        scroll-snap-align: start;
      }
      .mobile-buy-bar {
        position: sticky;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 30;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: center;
        margin: 26px calc((100vw - 100%) / -2) -72px;
        padding: 12px 18px;
        border-top: 1px solid rgba(61, 62, 91, 0.12);
        background: rgba(255, 255, 255, 0.94);
        backdrop-filter: blur(12px);
        box-shadow: 0 -14px 32px rgba(41, 42, 63, 0.12);
      }
      .mobile-buy-bar strong {
        color: var(--primary);
        font-size: 18px;
      }
      .mobile-buy-bar span {
        display: block;
        color: var(--muted);
        font-size: 12px;
      }
      .mobile-buy-bar__actions {
        display: flex;
        gap: 8px;
      }
      .mobile-buy-bar .product-action {
        min-height: 42px;
        padding: 0 14px;
        font-size: 13px;
      }
    }
    @media (max-width: 560px) {
      .product-info h1 {
        font-size: 29px;
      }
      .product-price strong {
        font-size: 27px;
      }
      .qty-row {
        align-items: flex-start;
        flex-direction: column;
      }
      .product-benefits {
        grid-template-columns: 1fr;
      }
      .related-card {
        flex-basis: 86%;
      }
      .mobile-buy-bar {
        grid-template-columns: 1fr;
      }
      .mobile-buy-bar__actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
    }

block content
  - const galleryImages = product.images && product.images.length ? product.images : [product.image]
  - const selectedAttributes = product.primaryVariant && product.primaryVariant.attributesText ? product.primaryVariant.attributesText : 'Phiên bản tiêu chuẩn'
  - const selectedSku = product.primaryVariant && product.primaryVariant.sku ? product.primaryVariant.sku : 'Đang cập nhật'
  - const stockText = product.isInStock ? `Còn ${product.totalStock} sản phẩm` : 'Tạm hết hàng'
  - const specRows = [{ label: 'Thương hiệu', value: product.brand || 'SoundHouse' }, { label: 'Danh mục', value: product.category ? product.category.name : 'Loa Bluetooth' }, { label: 'Kết nối', value: 'Bluetooth 5.2' }, { label: 'Pin', value: 'Lên đến 20 giờ' }, { label: 'Chống nước', value: 'IP67' }, { label: 'SKU', value: selectedSku }, { label: 'Tình trạng', value: product.isInStock ? 'Còn hàng' : 'Tạm hết hàng' }, { label: 'Đánh giá', value: product.ratingText || 'Chưa có đánh giá' }]
  .product-detail-page
    .product-shell
      nav.product-breadcrumb(aria-label="Breadcrumb")
        a(href="/") Trang chủ
        span /
        if product.category
          a(href=`/category/${product.category.slug}`)= product.category.name
          span /
        span= product.name

      section.product-main
        .product-gallery
          .product-gallery__stage(data-gallery-stage)
            img.product-gallery__image(src=product.image alt=product.name data-product-image)
          .product-gallery__thumbs(aria-label="Ảnh sản phẩm")
            each image, index in galleryImages
              button.product-gallery__thumb(type="button" class=index === 0 ? 'is-active' : '' data-gallery-thumb data-gallery-src=image aria-label=`Xem ảnh ${index + 1}`)
                img(src=image alt=`${product.name} ảnh ${index + 1}` loading="lazy")

        aside.product-info
          .product-info__brandline
            span.product-tag= product.brand || 'SoundHouse'
            if product.category
              span.product-tag= product.category.name
            span.product-tag.product-tag--accent Premium
          h1= product.name
          .product-rating
            span.product-rating__stars(data-product-stars) ★★★★★
            span(data-product-rating-text)= product.ratingText
            span |
            span(data-product-rating-count)= product.ratingCount ? `${product.ratingCount} đánh giá` : 'Sản phẩm mới'
          .product-price
            strong(data-product-price)= product.priceText
            if product.compareAtPriceText
              span(data-product-old-price)= product.compareAtPriceText
            else
              span(data-product-old-price)
            if product.discountPercentage
              span.product-tag.product-tag--accent= `Giảm ${product.discountPercentage}%`
          p.product-summary= product.shortDescription || product.description || 'Mẫu loa Bluetooth cao cấp với thiết kế tinh tế, âm thanh mạnh mẽ và trải nghiệm nghe nhạc hiện đại.'
          .product-status(class=product.isInStock ? '' : 'is-out' data-product-stock)= stockText

          if product.variants && product.variants.length
            .product-option
              .product-option__head
                span Màu sắc / phiên bản
                span.product-option__selected(data-product-attributes)= selectedAttributes
              .variant-list
                each variant in product.variants
                  button.variant-chip(
                    type="button"
                    class=(product.primaryVariant && variant.id === product.primaryVariant.id ? 'is-active' : '')
                    data-variant-btn=variant.id
                    disabled=variant.stock <= 0
                  )= variant.attributesText || variant.sku || 'Phiên bản'
          else
            .product-option
              .product-option__head
                span Phiên bản
                span.product-option__selected(data-product-attributes)= selectedAttributes

          .qty-row
            label Số lượng
            .qty-box
              button(type="button" data-qty-btn="-1" aria-label="Giảm số lượng") -
              strong(data-product-qty) 1
              button(type="button" data-qty-btn="1" aria-label="Tăng số lượng") +

          .product-actions
            button.product-action.product-action--cart(type="button" data-product-add-cart disabled=!product.isInStock) Thêm vào giỏ hàng
            button.product-action.product-action--buy(type="button" data-product-buy-now disabled=!product.isInStock) Mua ngay

          .product-benefits
            .product-benefit
              strong Chính hãng
              span Bảo hành theo chính sách thương hiệu.
            .product-benefit
              strong Tư vấn nhanh
              span Hỗ trợ chọn loa phù hợp không gian.
            .product-benefit
              strong Giao hàng
              span Đóng gói an toàn, giao toàn quốc.

      section.product-section.product-description
        h2 Mô tả sản phẩm
        .product-description__content= product.description || product.shortDescription || 'Thông tin chi tiết đang được cập nhật.'
        .product-description__bullets
          span Âm thanh cân bằng, dễ nghe
          span Thiết kế phù hợp không gian hiện đại
          span Kết nối Bluetooth ổn định

      section.product-section
        h2 Thông số kỹ thuật
        .spec-table
          each spec in specRows
            .spec-row
              span= spec.label
              strong= spec.value

      section.product-section
        h2 Đánh giá khách hàng
        .review-layout
          .review-list(data-product-review-list)
          aside
            form.review-form(data-product-review-form)
              .field
                label(for="review-author") Tên hiển thị
                input#review-author(type="text" name="authorName" placeholder="Nguyễn Văn A" required)
              .field
                label(for="review-rating") Số sao
                select#review-rating(name="rating")
                  option(value="5") 5 sao
                  option(value="4") 4 sao
                  option(value="3") 3 sao
                  option(value="2") 2 sao
                  option(value="1") 1 sao
              .field
                label(for="review-comment") Nhận xét
                textarea#review-comment(name="comment" rows="5" placeholder="Cảm nhận của bạn về sản phẩm..." required)
              button.btn(type="submit") Gửi đánh giá
            p.muted(data-product-review-empty style="margin:14px 0 0") Chưa có đánh giá nào cho sản phẩm này.

      if relatedProducts && relatedProducts.length
        section.product-section.product-related
          h2 Sản phẩm liên quan
          .related-grid
            each item in relatedProducts
              a.related-card(href=`/products/${item.slug}`)
                .related-card__media
                  img(src=item.image alt=item.name loading="lazy")
                .related-card__body
                  span.related-card__brand= item.brand
                  h3= item.name
                  span.related-card__price= item.priceText

      .mobile-buy-bar
        div
          strong(data-mobile-product-price)= product.priceText
          span= product.name
        .mobile-buy-bar__actions
          button.product-action.product-action--cart(type="button" data-product-add-cart disabled=!product.isInStock) Thêm giỏ
          button.product-action.product-action--buy(type="button" data-product-buy-now disabled=!product.isInStock) Mua ngay

  div(data-product-root data-product=JSON.stringify(product).replace(/</g, '&lt;') hidden)

block scripts
  script(type="module" src="/js/product.js")
