extends ../../layouts/storefront

block head
  style.
    .product-detail-page,
    .product-detail-page button,
    .product-detail-page input,
    .product-detail-page select,
    .product-detail-page textarea {
      font-family: "Be Vietnam Pro", sans-serif;
      -webkit-tap-highlight-color: transparent;
    }
    .product-detail-page {
      background:
        linear-gradient(180deg, rgba(61, 62, 91, 0.08), rgba(61, 62, 91, 0) 360px),
        #f7f8fc;
      padding: 36px 0 0;
    }
    .product-shell {
      width: var(--shell);
      margin: 0 auto;
    }
    .product-breadcrumb {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 9px;
      margin-bottom: 24px;
      color: var(--muted);
      font-size: 14px;
    }
    .product-breadcrumb a {
      color: var(--primary);
      font-weight: 700;
      text-decoration: none;
    }
    .product-main {
      display: grid;
      grid-template-columns: minmax(0, 55fr) minmax(390px, 45fr);
      gap: 44px;
      align-items: start;
      padding: 42px;
      border-radius: 26px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 22px 54px rgba(41, 42, 63, 0.1);
      animation: detailReveal 0.55s ease both;
    }
    .product-gallery {
      min-width: 0;
    }
    .product-gallery__stage {
      position: relative;
      display: grid;
      place-items: center;
      min-height: 560px;
      border-radius: 24px;
      background:
        radial-gradient(circle at 50% 35%, rgba(61, 62, 91, 0.12), rgba(61, 62, 91, 0.04) 58%, rgba(61, 62, 91, 0.02)),
        #f4f5fa;
      box-shadow: inset 0 0 0 1px rgba(61, 62, 91, 0.06);
      overflow: hidden;
    }
    .product-gallery__stage::after {
      content: "";
      position: absolute;
      inset: auto 10% 42px;
      height: 24px;
      border-radius: 50%;
      background: rgba(38, 39, 61, 0.16);
      filter: blur(18px);
    }
    .product-gallery__image {
      position: relative;
      z-index: 1;
      width: min(86%, 560px);
      max-height: 500px;
      object-fit: contain;
      filter: drop-shadow(0 24px 28px rgba(41, 42, 63, 0.14));
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .product-gallery__stage:hover .product-gallery__image {
      transform: scale(1.05);
    }
    .product-gallery__image.is-fading {
      opacity: 0;
    }
    .product-gallery__thumbs {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(86px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .product-gallery__thumb {
      height: 88px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(61, 62, 91, 0.12);
      border-radius: 16px;
      background: #fff;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .product-gallery__thumb:hover,
    .product-gallery__thumb.is-active {
      transform: translateY(-2px);
      border-color: rgba(61, 62, 91, 0.42);
      box-shadow: 0 14px 26px rgba(41, 42, 63, 0.1);
    }
    .product-gallery__thumb img {
      width: 76%;
      height: 72px;
      object-fit: contain;
    }
    .product-info {
      position: sticky;
      top: 112px;
      min-width: 0;
    }
    .product-info__brandline {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
    }
    .product-tag {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(61, 62, 91, 0.08);
      color: var(--primary);
      font-size: 13px;
      font-weight: 800;
    }
    .product-tag--accent {
      background: rgba(242, 196, 109, 0.28);
      color: #7a5410;
    }
    .product-info h1 {
      margin: 0;
      color: var(--primary-dark);
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 42px;
      line-height: 1.12;
      letter-spacing: 0;
    }
    .product-rating {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      margin: 16px 0 0;
      color: var(--text-soft);
      font-size: 14px;
    }
    .product-rating__stars {
      color: #f2b84b;
      letter-spacing: 1px;
    }
    .product-price {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 12px;
      margin: 24px 0 16px;
    }
    .product-price strong {
      color: var(--primary);
      font-size: 36px;
      font-weight: 800;
    }
    .product-price span {
      color: var(--muted);
      font-size: 18px;
      text-decoration: line-through;
    }
    .product-summary {
      margin: 0;
      color: var(--text-soft);
      font-size: 16px;
      line-height: 1.8;
    }
    .product-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.12);
      color: #10734f;
      font-size: 14px;
      font-weight: 800;
    }
    .product-status.is-out {
      background: rgba(251, 113, 133, 0.12);
      color: #a92c44;
    }
    .product-option {
      margin-top: 26px;
      padding-top: 24px;
      border-top: 1px solid rgba(61, 62, 91, 0.12);
    }
    .product-option__head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
      color: var(--primary-dark);
      font-weight: 800;
    }
    .product-option__selected {
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
      text-align: right;
    }
    .variant-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .variant-chip {
      min-height: 42px;
      padding: 0 15px;
      border: 1px solid rgba(61, 62, 91, 0.16);
      border-radius: 999px;
      background: #fff;
      color: var(--primary);
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
      transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
    }
    .variant-chip:hover {
      transform: translateY(-2px);
      border-color: rgba(61, 62, 91, 0.36);
      box-shadow: 0 10px 20px rgba(41, 42, 63, 0.08);
    }
    .variant-chip.is-active {
      border-color: var(--primary);
      background: var(--primary);
      color: #fff;
    }
    .variant-chip:disabled {
      cursor: not-allowed;
      opacity: 0.45;
    }
    .qty-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      margin-top: 24px;
    }
    .qty-row label {
      color: var(--primary-dark);
      font-weight: 800;
    }
    .qty-box {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      padding: 7px;
      border: 1px solid rgba(61, 62, 91, 0.16);
      border-radius: 999px;
      background: #fff;
    }
    .qty-box button {
      width: 36px;
      height: 36px;
      border: 0;
      border-radius: 50%;
      background: rgba(61, 62, 91, 0.08);
      color: var(--primary);
      cursor: pointer;
      font-size: 18px;
      font-weight: 800;
      transition: transform 0.3s ease, background 0.3s ease;
    }
    .qty-box button:hover {
      transform: scale(1.03);
      background: rgba(61, 62, 91, 0.14);
    }
    .qty-box strong {
      min-width: 28px;
      text-align: center;
      color: var(--primary-dark);
    }
    .product-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 24px;
    }
    .product-action {
      min-height: 50px;
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 800;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    }
    .product-action:hover {
      transform: translateY(-2px);
    }
    .product-action:disabled {
      cursor: not-allowed;
      opacity: 0.55;
      transform: none;
      box-shadow: none;
    }
    .product-action--cart {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 16px 28px rgba(61, 62, 91, 0.22);
    }
    .product-action--cart:hover {
      background: var(--primary-dark);
      box-shadow: 0 22px 34px rgba(61, 62, 91, 0.28);
    }
    .product-action--buy {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #2f3048;
      box-shadow: 0 16px 28px rgba(242, 196, 109, 0.24);
    }
    .product-benefits {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 22px;
    }
    .product-benefit {
      padding: 13px;
      border-radius: 14px;
      background: rgba(61, 62, 91, 0.06);
      color: var(--text-soft);
      font-size: 13px;
      line-height: 1.5;
    }
    .product-benefit strong {
      display: block;
      margin-bottom: 4px;
      color: var(--primary-dark);
      font-size: 14px;
    }
    .product-section {
      margin-top: 34px;
      padding: 34px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 16px 34px rgba(41, 42, 63, 0.08);
      animation: detailReveal 0.55s ease both;
    }
    .product-section h2 {
      margin: 0 0 18px;
      color: var(--primary-dark);
      font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
      font-size: 30px;
      line-height: 1.16;
      letter-spacing: 0;
    }
    .product-description__content {
      color: var(--text-soft);
      line-height: 1.85;
      white-space: pre-line;
    }
    .product-description__bullets {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 22px;
    }
    .product-description__bullets span {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(61, 62, 91, 0.06);
      color: var(--primary-dark);
      font-weight: 800;
    }
    .spec-table {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border: 1px solid rgba(61, 62, 91, 0.12);
      border-radius: 18px;
      overflow: hidden;
    }
    .spec-row {
      display: grid;
      grid-template-columns: minmax(120px, 0.8fr) 1.2fr;
      gap: 14px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(61, 62, 91, 0.1);
      background: #fff;
    }
    .spec-row:nth-child(4n + 2),
    .spec-row:nth-child(4n + 3) {
      background: rgba(61, 62, 91, 0.04);
    }
    .spec-row:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
    .spec-row span {
      color: var(--muted);
      font-weight: 700;
    }
    .spec-row strong {
      color: var(--primary-dark);
      font-weight: 800;
    }
    .review-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
      align-items: start;
    }
    .review-list {
      display: grid;
      gap: 14px;
    }
    .review-item {
      padding: 16px;
      border-radius: 16px;
      background: rgba(61, 62, 91, 0.05);
      border: 1px solid rgba(61, 62, 91, 0.1);
    }
    .review-item__head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
      color: var(--primary-dark);
    }
    .review-stars {
      color: #f2b84b;
      letter-spacing: 2px;
    }
    .review-form {
      display: grid;
      gap: 14px;
      padding: 18px;
      border-radius: 18px;
      background: rgba(61, 62, 91, 0.05);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 22px;
    }
    .related-card {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #fff;
      color: inherit;
      text-decoration: none;
      box-shadow: 0 12px 26px rgba(41, 42, 63, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .related-card:hover {
      transform: translateY(-5px);
      border-color: rgba(61, 62, 91, 0.3);
      box-shadow: 0 20px 36px rgba(41, 42, 63, 0.14);
    }
    .related-card__media {
      height: 190px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: #f4f5fa;
      overflow: hidden;
    }
    .related-card__media img {
      width: 82%;
      height: 160px;
      object-fit: contain;
      transition: transform 0.3s ease;
    }
    .related-card:hover img {
      transform: scale(1.03);
    }
    .related-card__body {
      display: grid;
      gap: 8px;
      padding-top: 14px;
    }
    .related-card__body h3 {
      min-height: 46px;
      margin: 0;
      color: var(--primary-dark);
      font-size: 16px;
      line-height: 1.42;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }
    .related-card__brand {
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }
    .related-card__price {
      color: var(--primary);
      font-size: 18px;
      font-weight: 800;
    }
    .mobile-buy-bar {
      display: none;
    }
    .product-mobile-meta,
    .product-mobile-share,
    .product-mobile-bank,
    .product-mobile-quick,
    .product-mobile-description,
    .product-mobile-accordion,
    .product-mobile-related {
      display: none;
    }
    .product-gallery__actions {
      display: none;
    }
    .product-gallery__dots {
      display: none;
    }
    @keyframes detailReveal {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 1100px) {
      .product-main {
        grid-template-columns: minmax(0, 1fr) minmax(340px, 1fr);
        gap: 32px;
        padding: 30px;
      }
      .product-gallery__stage {
        min-height: 470px;
      }
      .product-info h1 {
        font-size: 34px;
      }
      .product-price strong {
        font-size: 30px;
      }
      .product-benefits,
      .product-description__bullets {
        grid-template-columns: 1fr;
      }
      .related-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 820px) {
      .product-detail-page {
        padding-top: 24px;
      }
      .product-main,
      .review-layout,
      .spec-table {
        grid-template-columns: 1fr;
      }
      .product-main {
        padding: 18px;
        border-radius: 20px;
      }
      .product-info {
        position: static;
      }
      .product-gallery__stage {
        min-height: 360px;
      }
      .product-gallery__image {
        max-height: 320px;
      }
      .product-gallery__thumbs {
        display: flex;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
      }
      .product-gallery__thumbs::-webkit-scrollbar {
        display: none;
      }
      .product-gallery__thumb {
        flex: 0 0 88px;
      }
      .product-actions {
        grid-template-columns: 1fr;
      }
      .product-section {
        padding: 24px 18px;
      }
      .spec-row:nth-child(n) {
        background: #fff;
      }
      .spec-row:nth-child(even) {
        background: rgba(61, 62, 91, 0.04);
      }
      .spec-row:nth-last-child(-n + 2) {
        border-bottom: 1px solid rgba(61, 62, 91, 0.1);
      }
      .spec-row:last-child {
        border-bottom: 0;
      }
      .related-grid {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 6px;
        scroll-snap-type: x proximity;
      }
      .related-card {
        flex: 0 0 78%;
        scroll-snap-align: start;
      }
      .mobile-buy-bar {
        position: sticky;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 30;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: center;
        margin: 26px calc((100vw - 100%) / -2) -72px;
        padding: 12px 18px;
        border-top: 1px solid rgba(61, 62, 91, 0.12);
        background: rgba(255, 255, 255, 0.94);
        backdrop-filter: blur(12px);
        box-shadow: 0 -14px 32px rgba(41, 42, 63, 0.12);
      }
      .mobile-buy-bar strong {
        color: var(--primary);
        font-size: 18px;
      }
      .mobile-buy-bar span {
        display: block;
        color: var(--muted);
        font-size: 12px;
      }
      .mobile-buy-bar__actions {
        display: flex;
        gap: 8px;
      }
      .mobile-buy-bar .product-action {
        min-height: 42px;
        padding: 0 14px;
        font-size: 13px;
      }
    }
    @media (max-width: 560px) {
      .product-info h1 {
        font-size: 29px;
      }
      .product-price strong {
        font-size: 27px;
      }
      .qty-row {
        align-items: flex-start;
        flex-direction: column;
      }
      .product-benefits {
        grid-template-columns: 1fr;
      }
      .related-card {
        flex-basis: 86%;
      }
      .mobile-buy-bar {
        grid-template-columns: 1fr;
      }
      .mobile-buy-bar__actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 767px) {
      .product-detail-page {
        background: #000;
        padding: 0 0 88px;
      }
      .product-shell {
        width: 100%;
      }
      .product-breadcrumb {
        gap: 6px;
        margin: 0;
        padding: 8px 10px;
        background: #000;
        color: rgba(255, 255, 255, 0.55);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .product-breadcrumb a,
      .product-breadcrumb span:last-child {
        color: #fff;
      }
      .product-breadcrumb a:first-child {
        color: rgba(255, 255, 255, 0.55);
      }
      .product-main {
        display: block;
        padding: 0;
        border: 0;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }
      .product-gallery__stage {
        min-height: 320px;
        border-radius: 0;
        background: linear-gradient(180deg, #10131a 0%, #171b26 100%);
        box-shadow: none;
      }
      .product-gallery__stage::after {
        display: none;
      }
      .product-gallery__image {
        width: 100%;
        height: 320px;
        max-height: none;
        object-fit: cover;
        filter: brightness(0.9) saturate(0.9);
      }
      .product-gallery__thumbs {
        display: none;
      }
      .product-gallery__actions {
        position: absolute;
        top: 18px;
        right: 12px;
        z-index: 3;
        display: grid;
        gap: 8px;
      }
      .product-gallery__quick {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.35);
        color: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(10px);
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }
      .product-gallery__quick:active {
        transform: scale(0.96);
      }
      .product-gallery__quick.is-active {
        color: #fff;
        background: rgba(99, 106, 232, 0.28);
      }
      .product-gallery__dots {
        position: absolute;
        left: 50%;
        bottom: 14px;
        z-index: 3;
        display: flex;
        gap: 6px;
        transform: translateX(-50%);
      }
      .product-gallery__dots .product-gallery__thumb {
        width: 10px;
        min-width: 10px;
        height: 3px;
        padding: 0;
        border: 0;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.3);
      }
      .product-gallery__dots .product-gallery__thumb img {
        display: none;
      }
      .product-gallery__dots .product-gallery__thumb.is-active {
        width: 24px;
        background: #636ae8;
        transform: none;
        box-shadow: none;
      }
      .product-info {
        padding: 12px 10px 18px;
        background: #000;
      }
      .product-mobile-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
      }
      .product-mobile-badge {
        min-height: 18px;
        display: inline-flex;
        align-items: center;
        padding: 0 8px;
        border-radius: 999px;
        background: #636ae8;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
      }
      .product-mobile-rating {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: rgba(255, 255, 255, 0.6);
        font-size: 11px;
      }
      .product-mobile-rating strong {
        color: #eab308;
      }
      .product-info__brandline,
      .product-rating,
      .product-status {
        display: none;
      }
      .product-info h1 {
        margin-top: 0;
        font-size: 21px;
        font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
        line-height: 1.22;
        color: #fff;
      }
      .product-price {
        gap: 8px;
        margin: 12px 0 0;
      }
      .product-price strong {
        color: #636ae8;
        font-size: 25px;
      }
      .product-price span {
        color: rgba(255, 255, 255, 0.45);
        font-size: 13px;
      }
      .product-price .product-tag--accent {
        min-height: 20px;
        padding: 0 8px;
        background: #ef4444;
        color: #fff;
        font-size: 10px;
      }
      .product-summary {
        display: none;
      }
      .product-option {
        margin-top: 14px;
        padding-top: 0;
        border-top: 0;
      }
      .product-option__head {
        display: block;
        margin-bottom: 8px;
      }
      .product-option__head span:first-child {
        display: block;
        margin-bottom: 4px;
        color: rgba(255, 255, 255, 0.6);
        font-size: 12px;
        font-weight: 500;
      }
      .product-option__selected {
        text-align: left;
        color: rgba(255, 255, 255, 0.8);
        font-size: 12px;
      }
      .variant-list {
        display: none;
      }
      .product-mobile-share,
      .product-mobile-bank,
      .product-mobile-quick,
      .product-mobile-description,
      .product-mobile-accordion,
      .product-mobile-related {
        display: block;
      }
      .product-mobile-variants {
        display: flex;
        gap: 8px;
        margin-top: 8px;
      }
      .product-mobile-color {
        width: 30px;
        height: 30px;
        display: inline-block;
        flex: 0 0 30px;
        border: 2px solid rgba(255, 255, 255, 0.14);
        border-radius: 999px;
        background: #111;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      }
      .product-mobile-color:disabled {
        opacity: 0.36;
        cursor: not-allowed;
      }
      .product-mobile-color.is-active {
        border-color: #636ae8;
        box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.14);
      }
      .product-mobile-color:not(:disabled):active {
        transform: scale(0.95);
      }
      .product-mobile-color--light {
        background: #d7d9de;
      }
      .product-mobile-color--blue {
        background: #5166a9;
      }
      .qty-row {
        align-items: flex-start;
        flex-direction: column;
        gap: 8px;
        margin-top: 14px;
      }
      .qty-row label {
        color: rgba(255, 255, 255, 0.6);
        font-size: 12px;
        font-weight: 500;
      }
      .qty-box {
        gap: 0;
        padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 6px;
        background: #111;
      }
      .qty-box button {
        width: 32px;
        height: 36px;
        border-radius: 0;
        background: transparent;
        color: #fff;
      }
      .qty-box strong {
        min-width: 32px;
        color: #fff;
        font-size: 13px;
      }
      .product-mobile-bank {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 10px;
        margin-top: 16px;
        padding: 12px;
        border-radius: 8px;
        background: #11116d;
        border: 1px solid rgba(141, 147, 255, 0.16);
      }
      .product-mobile-bank-icon {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.1);
        color: #8d93ff;
        font-size: 14px;
        font-weight: 700;
      }
      .product-mobile-bank strong {
        display: block;
        margin-bottom: 4px;
        color: #fff;
        font-size: 12px;
      }
      .product-mobile-bank p {
        margin: 0;
        color: rgba(255, 255, 255, 0.68);
        font-size: 11px;
        line-height: 1.45;
      }
      .product-actions {
        grid-template-columns: 1fr 1fr;
        margin-top: 14px;
      }
      .product-action {
        min-height: 44px;
        border-radius: 8px;
        box-shadow: none;
        font-size: 13px;
      }
      .product-benefits {
        display: none;
      }
      .product-mobile-quick {
        margin-top: 12px;
      }
      .product-mobile-quick-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
      }
      .product-mobile-quick-card {
        min-height: 58px;
        display: grid;
        place-items: center;
        gap: 4px;
        padding: 8px 6px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background: #141414;
        color: rgba(255, 255, 255, 0.78);
        font-size: 10px;
        text-align: center;
      }
      .product-mobile-quick-card strong {
        color: #636ae8;
        font-size: 15px;
      }
      .product-desktop-only {
        display: none;
      }
      .product-mobile-description {
        padding: 18px 10px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      .product-mobile-description h2 {
        margin: 0 0 12px;
        color: #fff;
        font-size: 18px;
        font-family: "Space Grotesk", "Be Vietnam Pro", sans-serif;
        line-height: 1.35;
      }
      .product-mobile-description p,
      .product-mobile-description li {
        color: rgba(255, 255, 255, 0.65);
        font-size: 13px;
        line-height: 1.65;
      }
      .product-mobile-description ul {
        margin: 12px 0 0;
        padding: 0;
        list-style: none;
      }
      .product-mobile-accordion-item {
        border-top: 1px solid rgba(255, 255, 255, 0.12);
      }
      .product-mobile-accordion-trigger {
        width: 100%;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        border: 0;
        background: #000;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
      }
      .product-mobile-accordion-trigger[aria-expanded="true"] span:last-child {
        transform: rotate(180deg);
      }
      .product-mobile-accordion-trigger span:last-child {
        color: rgba(255, 255, 255, 0.65);
        font-size: 14px;
        transition: transform 0.2s ease;
      }
      .product-mobile-accordion-panel {
        display: none;
        padding: 0 10px 16px;
      }
      .product-mobile-accordion-item.is-open .product-mobile-accordion-panel {
        display: block;
      }
      .product-mobile-accordion .spec-table {
        grid-template-columns: 1fr;
        border-radius: 10px;
        overflow: hidden;
      }
      .product-mobile-accordion .spec-row {
        grid-template-columns: 1fr;
        gap: 6px;
        padding: 12px;
        background: #141722 !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .product-mobile-accordion .spec-row span {
        color: rgba(255, 255, 255, 0.55);
      }
      .product-mobile-accordion .spec-row strong {
        color: #fff;
      }
      .product-mobile-accordion .review-form {
        padding: 0;
        background: transparent;
      }
      .product-mobile-accordion .review-item {
        background: #141722;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .product-mobile-accordion .field label,
      .product-mobile-accordion .muted {
        color: rgba(255, 255, 255, 0.62);
      }
      .product-mobile-accordion input,
      .product-mobile-accordion select,
      .product-mobile-accordion textarea {
        background: #141722;
        color: #fff;
        border-color: rgba(255, 255, 255, 0.08);
      }
      .product-mobile-faq {
        margin: 0;
        padding-left: 16px;
        color: rgba(255, 255, 255, 0.65);
        font-size: 12px;
        line-height: 1.7;
      }
      .product-mobile-related {
        padding: 22px 10px 28px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      .product-mobile-related-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
      }
      .product-mobile-related-head h2 {
        margin: 0;
        color: #fff;
        font-size: 16px;
      }
      .product-mobile-related-head a {
        color: #636ae8;
        font-size: 11px;
        text-decoration: none;
      }
      .product-mobile-related-list {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
      }
      .product-mobile-related-list::-webkit-scrollbar {
        display: none;
      }
      .product-mobile-related-card {
        min-width: 102px;
        max-width: 110px;
        color: inherit;
        text-decoration: none;
      }
      .product-mobile-related-card img {
        width: 100px;
        height: 100px;
        border-radius: 8px;
        object-fit: cover;
      }
      .product-mobile-related-card h3 {
        margin: 8px 0 4px;
        color: #fff;
        font-size: 10px;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .product-mobile-related-card span {
        color: #636ae8;
        font-size: 10px;
        font-weight: 700;
      }
      .mobile-buy-bar {
        display: none !important;
      }
      .site-footer {
        margin-top: 0;
        background: #2d2e45;
      }
      .site-footer__grid {
        padding-top: 34px;
      }
      .site-footer__brand {
        text-align: center;
      }
      .site-footer__brand-row {
        justify-content: center;
      }
    }

block content
  - const galleryImages = product.images && product.images.length ? product.images : [product.image]
  - const selectedAttributes = product.primaryVariant && product.primaryVariant.attributesText ? product.primaryVariant.attributesText : 'Phien ban tieu chuan'
  - const selectedSku = product.primaryVariant && product.primaryVariant.sku ? product.primaryVariant.sku : 'Dang cap nhat'
  - const stockText = product.isInStock ? `Con ${product.totalStock} san pham` : 'Tam het hang'
  - const specRows = [{ label: 'Thuong hieu', value: product.brand || 'SoundHouse' }, { label: 'Danh muc', value: product.category ? product.category.name : 'Tai nghe' }, { label: 'Ket noi', value: 'Bluetooth 5.2' }, { label: 'Pin', value: 'Len den 60 gio' }, { label: 'Chong nuoc', value: 'IP67' }, { label: 'SKU', value: selectedSku }, { label: 'Tinh trang', value: product.isInStock ? 'Con hang' : 'Tam het hang' }, { label: 'Danh gia', value: product.ratingText || 'Chua co danh gia' }]
  .product-detail-page
    .product-shell
      nav.product-breadcrumb(aria-label="Breadcrumb")
        a(href="/") Trang chu
        span >
        if product.category
          a(href=`/category/${product.category.slug}`)= product.category.name
          span >
        span= product.name

      section.product-main
        .product-gallery
          .product-gallery__stage(data-gallery-stage)
            .product-gallery__actions
              button.product-gallery__quick(type="button" data-product-share aria-label="Chia se") ?
              button.product-gallery__quick(type="button" data-product-favorite aria-label="Yeu thich" aria-pressed="false") ?
            img.product-gallery__image(src=product.image alt=product.name data-product-image)
            .product-gallery__dots
              each image, index in galleryImages
                button.product-gallery__thumb(type="button" class=index === 0 ? 'is-active' : '' data-gallery-thumb data-gallery-src=image aria-label=`Xem anh ${index + 1}`)
          .product-gallery__thumbs(aria-label="Anh san pham")
            each image, index in galleryImages
              button.product-gallery__thumb(type="button" class=index === 0 ? 'is-active' : '' data-gallery-thumb data-gallery-src=image aria-label=`Xem anh ${index + 1}`)
                img(src=image alt=`${product.name} anh ${index + 1}` loading="lazy")

        aside.product-info
          .product-mobile-meta
            span.product-mobile-badge Ban chay
            .product-mobile-rating
              strong *
              span(data-product-rating-text)= product.ratingText
              span(data-product-rating-count)= product.ratingCount ? `(${product.ratingCount} danh gia)` : '(Moi)'
          .product-info__brandline
            span.product-tag= product.brand || 'SoundHouse'
            if product.category
              span.product-tag= product.category.name
            span.product-tag.product-tag--accent Premium
          h1= product.name
          .product-rating
            span.product-rating__stars(data-product-stars) *****
            span(data-product-rating-text)= product.ratingText
            span |
            span(data-product-rating-count)= product.ratingCount ? `${product.ratingCount} danh gia` : 'San pham moi'
          .product-price
            strong(data-product-price)= product.priceText
            if product.compareAtPriceText
              span(data-product-old-price)= product.compareAtPriceText
            else
              span(data-product-old-price)
            if product.discountPercentage
              span.product-tag.product-tag--accent= `-${product.discountPercentage}%`
          p.product-summary= product.shortDescription || product.description || 'Mau tai nghe cao cap voi am thanh manh me va trai nghiem nghe hien dai.'
          .product-status(class=product.isInStock ? '' : 'is-out' data-product-stock)= stockText

          if product.variants && product.variants.length
            .product-option
              .product-option__head
                span Mau sac / phien ban
                span.product-option__selected(data-product-attributes)= selectedAttributes
              .product-mobile-variants
                each variant, index in product.variants
                  button.product-mobile-color(
                    type="button"
                    class=`${product.primaryVariant && variant.id === product.primaryVariant.id ? 'is-active ' : ''}${index === 1 ? 'product-mobile-color--light' : ''}${index === 2 ? ' product-mobile-color--blue' : ''}`
                    data-variant-btn=variant.id
                    disabled=variant.stock <= 0
                    aria-label=variant.attributesText || variant.sku || 'Phien ban'
                  )
              .variant-list
                each variant in product.variants
                  button.variant-chip(
                    type="button"
                    class=(product.primaryVariant && variant.id === product.primaryVariant.id ? 'is-active' : '')
                    data-variant-btn=variant.id
                    disabled=variant.stock <= 0
                  )= variant.attributesText || variant.sku || 'Phien ban'
          else
            .product-option
              .product-option__head
                span Phien ban
                span.product-option__selected(data-product-attributes)= selectedAttributes

          .qty-row
            label So luong
            .qty-box
              button(type="button" data-qty-btn="-1" aria-label="Giam so luong") -
              strong(data-product-qty) 1
              button(type="button" data-qty-btn="1" aria-label="Tang so luong") +

          .product-mobile-bank
            span.product-mobile-bank-icon ?
            div
              strong Uu dai chuyen khoan
              p Giam them 2% khi thanh toan qua chuyen khoan ngan hang. Noi dung: [Ma don hang] gui ve STK Vietcombank trong phan chan trang.

          .product-actions
            button.product-action.product-action--cart(type="button" data-product-add-cart disabled=!product.isInStock) Them vao gio hang
            button.product-action.product-action--buy(type="button" data-product-buy-now disabled=!product.isInStock) Mua ngay

          .product-mobile-quick
            .product-mobile-quick-grid
              .product-mobile-quick-card
                strong 24M
                span BH 24 Thang
              .product-mobile-quick-card
                strong 2H
                span Giao Hoa Toc
              .product-mobile-quick-card
                strong 7D
                span 7 Ngay Doi Tra

          .product-benefits
            .product-benefit
              strong Chinh hang
              span Bao hanh theo chinh sach thuong hieu.
            .product-benefit
              strong Tu van nhanh
              span Ho tro chon san pham phu hop khong gian.
            .product-benefit
              strong Giao hang
              span Dong goi an toan, giao toan quoc.

      section.product-mobile-description
        h2 Am thanh dinh cao, tinh lang tuyet doi
        p= product.description || product.shortDescription || 'Thong tin chi tiet dang duoc cap nhat.'
        ul
          li • Driver Carbon 40mm cho am bass sau va chi tiet.
          li • Thoi luong pin len den 60 gio lien tuc.
          li • Sac nhanh 10 phut dung duoc 5 gio.

      section.product-mobile-accordion
        .product-mobile-accordion-item(data-detail-accordion)
          button.product-mobile-accordion-trigger(type="button" data-detail-accordion-trigger aria-expanded="false")
            span Thong so ky thuat
            span v
          .product-mobile-accordion-panel(data-detail-accordion-panel)
            .spec-table
              each spec in specRows
                .spec-row
                  span= spec.label
                  strong= spec.value
        .product-mobile-accordion-item(data-detail-accordion)
          button.product-mobile-accordion-trigger(type="button" data-detail-accordion-trigger aria-expanded="false")
            span Danh gia khach hang (128)
            span v
          .product-mobile-accordion-panel(data-detail-accordion-panel)
            .review-list(data-product-review-list)
            aside
              form.review-form(data-product-review-form)
                .field
                  label(for="review-author-mobile") Ten hien thi
                  input#review-author-mobile(type="text" name="authorName" placeholder="Nguyen Van A" required)
                .field
                  label(for="review-rating-mobile") So sao
                  select#review-rating-mobile(name="rating")
                    option(value="5") 5 sao
                    option(value="4") 4 sao
                    option(value="3") 3 sao
                    option(value="2") 2 sao
                    option(value="1") 1 sao
                .field
                  label(for="review-comment-mobile") Nhan xet
                  textarea#review-comment-mobile(name="comment" rows="5" placeholder="Cam nhan cua ban ve san pham..." required)
                button.btn(type="submit") Gui danh gia
              p.muted(data-product-review-empty style="margin:14px 0 0") Chua co danh gia nao cho san pham nay.
        .product-mobile-accordion-item(data-detail-accordion)
          button.product-mobile-accordion-trigger(type="button" data-detail-accordion-trigger aria-expanded="false")
            span Cau hoi thuong gap (Q&A)
            span v
          .product-mobile-accordion-panel(data-detail-accordion-panel)
            ul.product-mobile-faq
              li San pham co ho tro ANC va Bluetooth 5.2.
              li Bao hanh chinh hang 24 thang tai SoundHouse.
              li Ho tro doi tra trong 7 ngay neu co loi nha san xuat.

      if relatedProducts && relatedProducts.length
        section.product-mobile-related
          .product-mobile-related-head
            h2 San pham tuong tu
            a(href="/category") Xem them
          .product-mobile-related-list
            each item in relatedProducts
              a.product-mobile-related-card(href=`/products/${item.slug}`)
                img(src=item.image alt=item.name loading="lazy")
                h3= item.name
                span= item.priceText

      .product-desktop-only
        section.product-section.product-description
          h2 Mo ta san pham
          .product-description__content= product.description || product.shortDescription || 'Thong tin chi tiet dang duoc cap nhat.'
          .product-description__bullets
            span Am thanh can bang, de nghe
            span Thiet ke phu hop khong gian hien dai
            span Ket noi Bluetooth on dinh

        section.product-section
          h2 Thong so ky thuat
          .spec-table
            each spec in specRows
              .spec-row
                span= spec.label
                strong= spec.value

        section.product-section
          h2 Danh gia khach hang
          .review-layout
            .review-list(data-product-review-list)
            aside
              form.review-form(data-product-review-form)
                .field
                  label(for="review-author") Ten hien thi
                  input#review-author(type="text" name="authorName" placeholder="Nguyen Van A" required)
                .field
                  label(for="review-rating") So sao
                  select#review-rating(name="rating")
                    option(value="5") 5 sao
                    option(value="4") 4 sao
                    option(value="3") 3 sao
                    option(value="2") 2 sao
                    option(value="1") 1 sao
                .field
                  label(for="review-comment") Nhan xet
                  textarea#review-comment(name="comment" rows="5" placeholder="Cam nhan cua ban ve san pham..." required)
                button.btn(type="submit") Gui danh gia
              p.muted(data-product-review-empty style="margin:14px 0 0") Chua co danh gia nao cho san pham nay.

        if relatedProducts && relatedProducts.length
          section.product-section.product-related
            h2 San pham lien quan
            .related-grid
              each item in relatedProducts
                a.related-card(href=`/products/${item.slug}`)
                  .related-card__media
                    img(src=item.image alt=item.name loading="lazy")
                  .related-card__body
                    span.related-card__brand= item.brand
                    h3= item.name
                    span.related-card__price= item.priceText

      .mobile-buy-bar
        div
          strong(data-mobile-product-price)= product.priceText
          span= product.name
        .mobile-buy-bar__actions
          button.product-action.product-action--cart(type="button" data-product-add-cart disabled=!product.isInStock) Them gio
          button.product-action.product-action--buy(type="button" data-product-buy-now disabled=!product.isInStock) Mua ngay

  div(data-product-root data-product=JSON.stringify(product).replace(/</g, '&lt;') hidden)
block scripts
  script(type="module" src="/js/product.js")

