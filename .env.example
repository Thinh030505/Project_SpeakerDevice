PORT=3000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/product-management

JWT_SECRET=replace-with-your-access-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM_NAME=SoundHouse

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUEST=100
RATE_LIMIT_SKIP_SUCCESSFUL=false
DEBUG_LOGS=false
SKIP_EXTERNAL_SERVICES=false
SKIP_EMAIL_VERIFY=false

